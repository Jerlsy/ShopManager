        <Application x:Class="ShopManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:ShopManager.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:ShopManager">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light"
                                 PrimaryColor="BlueGrey"
                                 SecondaryColor="Blue"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <CornerRadius x:Key="MaterialDesign.SmallComponent.CornerRadius">5</CornerRadius>

            <!-- ── 全域字型（由 AppearanceService 於啟動時覆寫） ── -->
            <FontFamily x:Key="AppFontFamily">pack://application:,,,/Fonts/#Noto Sans TC</FontFamily>

            <!-- ── 比例字體大小（base=15，由 AppearanceService 動態更新） ── -->
            <sys:Double x:Key="FontSizeCaption">12</sys:Double>
            <sys:Double x:Key="FontSizeSmall">13</sys:Double>
            <sys:Double x:Key="FontSizeSmallBody">14</sys:Double>
            <sys:Double x:Key="FontSizeBody">15</sys:Double>
            <sys:Double x:Key="FontSizeBodyPlus">16</sys:Double>
            <sys:Double x:Key="FontSizeHeading">18</sys:Double>
            <sys:Double x:Key="FontSizeSubTitle">20</sys:Double>
            <sys:Double x:Key="FontSizeSectionAlt">22</sys:Double>
            <sys:Double x:Key="FontSizeSection">24</sys:Double>
            <sys:Double x:Key="FontSizeDialogTitle">26</sys:Double>
            <sys:Double x:Key="FontSizeListTitle">28</sys:Double>
            <sys:Double x:Key="FontSizeWindowTitle">30</sys:Double>
            <sys:Double x:Key="FontSizePageTitle">32</sys:Double>

            <!-- ── 基礎文字樣式 ── -->
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeBody}"/>
            </Style>

            <!-- ── TextBox 全域樣式（圓角與字體縮放同步） ── -->
            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeBody}"/>
                <Setter Property="md:TextFieldAssist.TextFieldCornerRadius" Value="5"/>
                <Setter Property="md:TextFieldAssist.HasOutlinedTextField" Value="True"/>
            </Style>
            <!-- ── ComboBox 全域樣式（圓角與字體縮放同步） ── -->
            <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeBody}"/>
                <Setter Property="TextElement.FontSize" Value="{DynamicResource FontSizeBody}"/>
                <Setter Property="md:TextFieldAssist.TextFieldCornerRadius" Value="5"/>
                <Setter Property="md:TextFieldAssist.HasOutlinedTextField" Value="True"/>
            </Style>

            <!-- ── 可選取文字（模擬 TextBlock，無外框） ── -->
            <Style x:Key="SelectableTextStyle" TargetType="{x:Type TextBox}">
                <Setter Property="IsReadOnly"              Value="True"/>
                <Setter Property="Background"              Value="Transparent"/>
                <Setter Property="BorderThickness"         Value="0"/>
                <Setter Property="Padding"                 Value="0"/>
                <Setter Property="IsTabStop"               Value="False"/>
                <Setter Property="FocusVisualStyle"        Value="{x:Null}"/>
                <Setter Property="TextWrapping"            Value="Wrap"/>
                <Setter Property="VerticalContentAlignment" Value="Top"/>
                <Setter Property="FontFamily"              Value="{DynamicResource AppFontFamily}"/>
                <Setter Property="FontSize"                Value="{DynamicResource AppFontSize}"/>
                <Setter Property="Foreground"              Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TextBox}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── PasswordBox 全域樣式 ── -->
            <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeBody}"/>
                <Setter Property="md:TextFieldAssist.TextFieldCornerRadius" Value="5"/>
                <Setter Property="md:TextFieldAssist.HasOutlinedTextField" Value="True"/>
            </Style>

            <Color x:Key="AppShellBackgroundColor">#EEF3F8</Color>
            <Color x:Key="AppShellGradientStartColor">#F4F8FC</Color>
            <Color x:Key="AppShellGradientMidColor">#EAF1F7</Color>
            <Color x:Key="AppShellGradientEndColor">#E3ECF4</Color>

            <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="{DynamicResource AppShellBackgroundColor}"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FCFDFE"/>
            <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#F8FBFD"/>
            <SolidColorBrush x:Key="AppPanelBrush" Color="#F3F7FA"/>
            <SolidColorBrush x:Key="AppPanelAltBrush" Color="#F7FAFC"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#120F172A"/>
            <SolidColorBrush x:Key="AppSelectionBrush" Color="#DCEBFA"/>
            <SolidColorBrush x:Key="AppHoverBrush" Color="#EDF4FB"/>
            <SolidColorBrush x:Key="AppInfoBrush" Color="#EAF3FA"/>
            <SolidColorBrush x:Key="AppInfoForegroundBrush" Color="#314A61"/>
            <SolidColorBrush x:Key="AppSubtleForegroundBrush" Color="#9E0F172A"/>
            <SolidColorBrush x:Key="AppSubtleForegroundStrongBrush" Color="#B00F172A"/>
            <SolidColorBrush x:Key="AppPrimaryPreviewBrush" Color="#546E7A"/>
            <SolidColorBrush x:Key="AppSecondaryPreviewBrush" Color="#29B6F6"/>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <helpers:NullToStringConverter x:Key="NullToStringConverter"/>
            <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <helpers:SalaryTypeDisplayConverter x:Key="SalaryTypeDisplayConverter"/>
            <helpers:SalaryTypeVisibilityConverter x:Key="SalaryTypeVisibilityConverter"/>
            <helpers:DateOnlyConverter x:Key="DateOnlyConverter"/>
            <helpers:NullableDateOnlyConverter x:Key="NullableDateOnlyConverter"/>
            <helpers:NameInitialConverter x:Key="NameInitialConverter"/>
            <helpers:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>
            <helpers:MultiplyDoubleConverter x:Key="MultiplyDoubleConverter"/>
            <helpers:HexToBrushConverter x:Key="HexToBrushConverter"/>
            <helpers:ColorMatchConverter x:Key="ColorMatchConverter"/>
            <helpers:BytesToImageConverter x:Key="BytesToImageConverter"/>
            <helpers:ViewModeVisibilityConverter x:Key="ViewModeVisibilityConverter"/>
            <helpers:ConstraintTypeToLabelConverter x:Key="ConstraintTypeToLabelConverter"/>
            <helpers:BoolInverseConverter x:Key="BoolInverseConverter"/>
            <helpers:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
            <helpers:BonusTypeToCustomLabelVisibilityConverter x:Key="BonusTypeToCustomLabelVisibilityConverter"/>
            <helpers:BonusTypeToPresetLabelVisibilityConverter x:Key="BonusTypeToPresetLabelVisibilityConverter"/>

            <!-- ── 響應式佈局尺寸（由 App.xaml.cs ApplyLayoutScale 依螢幕寬度覆寫） ── -->
            <sys:Double x:Key="LayoutNavExpandedWidth">200</sys:Double>
            <GridLength x:Key="LayoutSideListGridWidth">220</GridLength>
            <sys:Double x:Key="LayoutEmployeeCardWidth">240</sys:Double>

            <!-- ── 統一 UI 樣式管理 ── -->
            <Thickness x:Key="PageMargin">16,6,16,14</Thickness>

            <!-- TextBlock 語意樣式 -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeSection}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeHeading}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,0,0,10"/>
            </Style>

            <Style x:Key="ItemTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeBodyPlus}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="FormSectionStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Margin"     Value="0,0,0,8"/>
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Margin"     Value="0,0,0,4"/>
            </Style>

            <Style x:Key="SubtleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Foreground" Value="{DynamicResource AppSubtleForegroundBrush}"/>
            </Style>

            <Style x:Key="BodyTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
            </Style>

            <Style x:Key="CaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="{DynamicResource FontSizeSmall}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSubtleForegroundBrush}"/>
            </Style>

            <!-- Border 容器樣式（CardBorderStyle = 員工薪資卡片用，等同 SectionCardStyle + 較小 padding） -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="Background"      Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="16,12"/>
            </Style>

            <Style x:Key="PageHeaderStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="16"/>
                <Setter Property="Background"      Value="{DynamicResource AppSurfaceAltBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="16,12"/>
                <Setter Property="Margin"          Value="0,0,0,10"/>
            </Style>

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="16"/>
                <Setter Property="Background"      Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14"/>
            </Style>

            <Style x:Key="ItemCardStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="Background"      Value="{DynamicResource AppPanelAltBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="12,10"/>
            </Style>

            <Style x:Key="EditFormCardStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="16"/>
                <Setter Property="Background"      Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="20"/>
            </Style>

            <Style x:Key="InfoBoxStyle" TargetType="Border">
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="Background"      Value="{DynamicResource AppInfoBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,10"/>
            </Style>
            <!-- 漫畫對話框 ToolTip 樣式 -->
            <!-- 用於靜態佈局元素（月視圖）：tooltip 在元素上方，箭頭朝下 -->
            <Style x:Key="SpeechBubbleToolTip" TargetType="ToolTip">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Placement" Value="Top"/>
                <Setter Property="VerticalOffset" Value="-4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <StackPanel>
                                <Border Background="#FFF9C4" BorderBrush="#4E342E" BorderThickness="2.5"
                                        CornerRadius="12" Padding="12,8">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.25" Color="#000000"/>
                                    </Border.Effect>
                                    <ContentPresenter/>
                                </Border>
                                <Grid Height="12" Margin="0,-2,0,0">
                                    <Path Fill="#4E342E" HorizontalAlignment="Center" Data="M 0,0 L 17,0 L 8.5,12 Z"/>
                                    <Path Fill="#FFF9C4" HorizontalAlignment="Center" Data="M 2.5,0 L 14.5,0 L 8.5,9 Z"/>
                                </Grid>
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- 用於週/日視圖 BlockMargin 絕對定位元素：Custom 定位由 code-behind 計算，tooltip 在 block 正上方置中，箭頭朝下 -->
            <Style x:Key="SpeechBubbleCustomToolTip" TargetType="ToolTip">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Placement" Value="Custom"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <StackPanel>
                                <Border Background="#FFF9C4" BorderBrush="#4E342E" BorderThickness="2.5"
                                        CornerRadius="12" Padding="12,8">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.25" Color="#000000"/>
                                    </Border.Effect>
                                    <ContentPresenter/>
                                </Border>
                                <Grid Height="12" Margin="0,-2,0,0">
                                    <Path Fill="#4E342E" HorizontalAlignment="Center" Data="M 0,0 L 17,0 L 8.5,12 Z"/>
                                    <Path Fill="#FFF9C4" HorizontalAlignment="Center" Data="M 2.5,0 L 14.5,0 L 8.5,9 Z"/>
                                </Grid>
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
