<UserControl x:Class="ShopManager.Views.Dialogs.EmploymentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="420">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
            CornerRadius="20" Padding="28,24,28,16">
        <StackPanel>
            <TextBlock Text="到職設定"
                       FontSize="{DynamicResource FontSizeDialogTitle}" FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="面試日期（選填）" Style="{StaticResource FieldLabelStyle}"/>
            <DatePicker x:Name="InterviewDatePicker"
                        md:HintAssist.Hint="選擇面試日期"
                        md:TextFieldAssist.HasClearButton="True"
                        Margin="0,0,0,16"/>

            <TextBlock Text="到職日期 *" Style="{StaticResource FieldLabelStyle}"/>
            <DatePicker x:Name="HireDatePicker"
                        md:HintAssist.Hint="選擇到職日期"
                        Margin="0,0,0,4"/>
            <TextBlock x:Name="HireDateError"
                       Text="到職日期為必填" Foreground="#C62828" FontSize="11"
                       Visibility="Collapsed" Margin="0,2,0,12"/>

            <TextBlock Text="離職日期（在職員工留空）" Style="{StaticResource FieldLabelStyle}"/>
            <DatePicker x:Name="ResignDatePicker"
                        md:HintAssist.Hint="選擇離職日期"
                        md:TextFieldAssist.HasClearButton="True"
                        Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{x:Static md:DialogHost.CloseDialogCommand}"
                        CommandParameter="{x:Null}"
                        Margin="0,0,8,0"/>
                <Button Content="確認"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Click="OkButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
