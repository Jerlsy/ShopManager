<UserControl x:Class="ShopManager.Views.ShopSettings.ShopSettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer Padding="28,8,28,28"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1080">
            <Border CornerRadius="28"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    Padding="24"
                    Margin="0,0,0,20">
                <TextBlock Text="店舖設定"
                           FontSize="30"
                           FontWeight="SemiBold"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Padding="22"
                        CornerRadius="28"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="店鋪資訊"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="管理店名、地址、電話與其他聯絡方式。"
                                   Margin="0,6,0,18"
                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>

                        <TextBox md:HintAssist.Hint="店鋪名稱 *"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,14"/>
                        <TextBox md:HintAssist.Hint="地址"
                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,14"/>
                        <TextBox md:HintAssist.Hint="聯絡電話"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,18"/>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="其他聯絡方式"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AddContactCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0"/>
                                    <TextBlock Text="新增"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding ContactInfos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            CornerRadius="20"
                                            Background="{DynamicResource AppPanelAltBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0"
                                                      Margin="0,0,8,0"
                                                      ItemsSource="{Binding DataContext.ContactTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding Type}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      md:HintAssist.Hint="類型"/>
                                            <TextBox Grid.Column="1"
                                                     Margin="0,0,8,0"
                                                     Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     md:HintAssist.Hint="顯示名稱"/>
                                            <TextBox Grid.Column="2"
                                                     Margin="0,0,8,0"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     md:HintAssist.Hint="帳號 / 網址 / 電話"/>
                                            <Button Grid.Column="3"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.RemoveContactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="22"
                        CornerRadius="28"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="行事曆規則"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="控制一週起始日、每週固定店休日，以及國定假日是否休假。"
                                   Margin="0,6,0,18"
                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>

                        <Border Padding="14"
                                Background="{DynamicResource AppPanelAltBrush}"
                                CornerRadius="20"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="預設一週起始日"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding WeekStartOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding WeekStartDay}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          md:HintAssist.Hint="起始日"
                                          Width="220"
                                          HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Padding="14"
                                Background="{DynamicResource AppPanelAltBrush}"
                                CornerRadius="20"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="每週固定店休日"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ClosedDayOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Label}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="0,0,16,8"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Padding="14"
                                Background="{DynamicResource AppPanelAltBrush}"
                                CornerRadius="20"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="國定假日是否休假"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton IsChecked="{Binding NationalHolidaysOff}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                    <TextBlock Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="照常營業"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NationalHolidaysOff}" Value="True">
                                                        <Setter Property="Text" Value="國定假日休假"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="22"
                    CornerRadius="28"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="介面套版與配色"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="所有頁面都會同步套用目前套版；內含多組淺色 preset、1 組深色 preset，最後可自訂 HEX 配色。"
                               Margin="0,6,0,18"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>

                    <WrapPanel Margin="0,0,0,16">
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetSkyBlueAccentCommand}" ToolTip="晴空藍" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#03A9F4" BorderBrush="#01579B"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetMintGreenAccentCommand}" ToolTip="薄荷綠" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#00C853" BorderBrush="#00471F"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetAmberOrangeAccentCommand}" ToolTip="暖陽橘" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#FFAB00" BorderBrush="#BF360C"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetRoyalPurpleAccentCommand}" ToolTip="皇家紫" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#673AB7" BorderBrush="#311B92"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetSoftPinkAccentCommand}" ToolTip="櫻花粉" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#E91E63" BorderBrush="#880E4F"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetVibrantRedAccentCommand}" ToolTip="熱情紅" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#F44336" BorderBrush="#B71C1C"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetOceanBlueAccentCommand}" ToolTip="深海藍" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#1565C0" BorderBrush="#0D47A1"/>
                        <Button Width="46" Height="46" Margin="0,0,10,10" Command="{Binding SetMidnightCyanAccentCommand}" ToolTip="深夜模式" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Background="#141E30" BorderBrush="#47DCFF"/>
                    </WrapPanel>

                    <Border Padding="14"
                            Margin="0,0,0,14"
                            Background="{DynamicResource AppPanelAltBrush}"
                            CornerRadius="20"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">
                        <DockPanel>
                            <TextBlock Text="目前套版"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding CurrentThemeName}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </DockPanel>
                    </Border>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 md:HintAssist.Hint="主色，例如 #1976D2"
                                 Text="{Binding CustomPrimaryHex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Column="2"
                                 md:HintAssist.Hint="輔色，例如 #009688"
                                 Text="{Binding CustomSecondaryHex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <Button Grid.Column="3"
                                Margin="12,0,0,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding ApplyCustomAccentCommand}">
                            <TextBlock Text="套用自訂色"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,28">
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,10,0"
                        Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="儲存設定"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.ValidationError}"
                        Command="{Binding CloseShopCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="關閉此店鋪"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
