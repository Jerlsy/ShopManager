<UserControl x:Class="ShopManager.Views.ShiftSettings.ShiftSettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="{StaticResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="班別設定" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="為各班別設定打卡時間與識別顏色，排班時可直接套用並快速新增排班"
                               Style="{StaticResource SubtleTextStyle}" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding StartNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="新增班別"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="班別列表" Style="{StaticResource SectionTitleStyle}"/>

                    <ListBox ItemsSource="{Binding Shifts}"
                             SelectedItem="{Binding SelectedShift}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    CornerRadius="20"
                                                    Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ItemCardStyle}" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12"
                                                        Height="12"
                                                        CornerRadius="6"
                                                        Margin="0,0,10,0"
                                                        Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}"
                                                        BorderBrush="White"
                                                        BorderThickness="1.5"/>
                                                <TextBlock Text="{Binding Alias}" Style="{StaticResource ItemTitleStyle}"/>
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,2"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource AppInfoBrush}"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                    <TextBlock Text="停用"
                                                               FontSize="{DynamicResource FontSizeCaption}"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="{DynamicResource FontSizeSmallBody}"
                                                       Foreground="{DynamicResource AppSubtleForegroundStrongBrush}">
                                                <Run Text="{Binding StartTime, StringFormat={}{0:HH\\:mm}}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndTime, StringFormat={}{0:HH\\:mm}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding WorkHours, StringFormat={}{0:F1}, Mode=OneWay}"/>
                                                <Run Text=" 小時"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="34" Height="34"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="34" Height="34"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <!-- 空狀態提示 -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <md:PackIcon Kind="ClockOutline"
                                 Width="80" Height="80"
                                 Opacity="0.12"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="請點選左側班別，或點選上方「新增班別」開始編輯"
                               Margin="0,20,0,0"
                               Opacity="0.45"
                               Style="{StaticResource ItemTitleStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 編輯表單 -->
                <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource EditFormCardStyle}" MaxWidth="640" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedShift, Converter={StaticResource NullToStringConverter}, ConverterParameter='新增班別|編輯班別'}"
                                       FontSize="{DynamicResource FontSizeListTitle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,24"/>

                            <TextBlock Text="班別名稱 *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                    
                                     Margin="0,0,0,20"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="上班時間" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding CommonTimes}"
                                              Text="{Binding EditStartTimeText, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                             
                                              md:HintAssist.Hint="HH:mm"/>
                                    <TextBlock Text="{Binding StartTimeError}"
                                               Margin="0,6,0,0"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                               Visibility="{Binding StartTimeError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="下班時間" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding CommonTimes}"
                                              Text="{Binding EditEndTimeText, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                             
                                              md:HintAssist.Hint="HH:mm"/>
                                    <TextBlock Text="{Binding EndTimeError}"
                                               Margin="0,6,0,0"
                                               FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                               Visibility="{Binding EndTimeError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource ItemCardStyle}" Margin="0,0,0,24" Padding="16,14">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ClockTimeFourOutline"
                                                 Width="20" Height="20"
                                                 Margin="0,0,10,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="預估工作時數: " FontSize="{DynamicResource FontSizeBody}"/>
                                        <Run Text="{Binding WorkHoursDisplay, Mode=OneWay}"
                                             FontSize="{DynamicResource FontSizeHeading}"
                                             FontWeight="Bold"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="識別顏色" Style="{StaticResource FormSectionStyle}"/>
                            <ItemsControl ItemsSource="{Binding ColorPalette}"
                                          Margin="0,0,0,24">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="38"
                                                Height="38"
                                                Margin="0,0,10,10"
                                                CornerRadius="12"
                                                Cursor="Hand"
                                                Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                                BorderThickness="0"
                                                MouseLeftButtonDown="ColorSwatch_Click">
                                            <!-- 選取時顯示外框光環 -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource ColorMatchConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.EditColor" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.9" Color="Black"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <!-- 選取打勾 -->
                                            <md:PackIcon Kind="Check"
                                                         Width="20" Height="20"
                                                         Foreground="White"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                <md:PackIcon.Style>
                                                    <Style TargetType="md:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource ColorMatchConverter}">
                                                                        <Binding/>
                                                                        <Binding Path="DataContext.EditColor" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </md:PackIcon.Style>
                                            </md:PackIcon>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Style="{StaticResource ItemCardStyle}" Margin="0,0,0,28" Padding="16,12">
                                <DockPanel>
                                    <TextBlock Text="啟用此班別"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton DockPanel.Dock="Right"
                                                  IsChecked="{Binding EditIsEnabled}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                  HorizontalAlignment="Right"/>
                                </DockPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Margin="0,0,12,0"
                                        Command="{Binding SaveCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/>
                                        <TextBlock Text="儲存班別"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="取消"
                                        Width="100"
                                        Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>