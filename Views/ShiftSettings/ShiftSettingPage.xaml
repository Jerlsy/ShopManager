<UserControl x:Class="ShopManager.Views.ShiftSettings.ShiftSettingPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════ -->
        <!-- 左側：班別清單                  -->
        <!-- ══════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">

            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <ui:TextBlock Text="班別設定" FontTypography="Title"
                              DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <ui:Button Content="新增班別"
                           Icon="{ui:SymbolIcon Symbol=Add24}"
                           Appearance="Primary"
                           HorizontalAlignment="Right"
                           Command="{Binding StartNewCommand}"/>
            </DockPanel>

            <ListBox ItemsSource="{Binding Shifts}"
                     SelectedItem="{Binding SelectedShift}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 色塊 + 班別資訊 -->
                            <Border Grid.Column="0" Width="6" CornerRadius="3"
                                    Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}"
                                    HorizontalAlignment="Left" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="14,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Alias}"
                                               FontWeight="SemiBold" FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <ui:Badge Content="停用" Appearance="Caution"
                                              Margin="6,0,0,0" VerticalAlignment="Center"
                                              Visibility="{Binding IsEnabled,
                                                  Converter={StaticResource BoolToVisibilityConverter},
                                                  ConverterParameter=Inverse}"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding StartTime, StringFormat={}{0:HH\\:mm}, Mode=OneWay}"/>
                                    <Run Text=" – "/>
                                    <Run Text="{Binding EndTime, StringFormat={}{0:HH\\:mm}, Mode=OneWay}"/>
                                    <Run Text=" (" />
                                    <Run Text="{Binding WorkHours, StringFormat={}{0:F1}, Mode=OneWay}"/>
                                    <Run Text="h)" />
                                </TextBlock>
                            </StackPanel>

                            <!-- 操作按鈕 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="4,0,0,0">
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Edit24}"
                                            Appearance="Secondary"
                                            Command="{Binding DataContext.StartEditCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,4,0"/>
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Delete24}"
                                            Appearance="Danger"
                                            Command="{Binding DataContext.DeleteCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ══════════════════════════════ -->
        <!-- 右側：編輯區 / 空白提示          -->
        <!-- ══════════════════════════════ -->
        <Grid Grid.Column="1">

            <!-- 空白提示（未開啟編輯時顯示） -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsEditing,
                            Converter={StaticResource BoolToVisibilityConverter},
                            ConverterParameter=Inverse}">
                <ui:SymbolIcon Symbol="Clock24" FontSize="52"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                <ui:TextBlock Text="請從左側選擇班別進行編輯，或點選「新增班別」"
                              FontTypography="Body"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- 編輯卡片 -->
            <Border Visibility="{Binding IsEditing,
                        Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="28"
                    VerticalAlignment="Top" MaxWidth="520" HorizontalAlignment="Left">
                <StackPanel>

                    <!-- 標題 -->
                    <ui:TextBlock Text="{Binding SelectedShift,
                                      Converter={StaticResource NullToStringConverter},
                                      ConverterParameter='新增班別|編輯班別'}"
                                  FontTypography="Subtitle" Margin="0,0,0,20"/>

                    <!-- 班別別名 -->
                    <ui:TextBlock Text="班別別名 *" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="例：早班、晚班、大夜班"
                                Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,0,20"/>

                    <!-- ── 時間選擇區 ───────────────────── -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 上班時間 -->
                        <StackPanel Grid.Column="0">
                            <ui:TextBlock Text="上班時間 *" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <!-- 下拉快選 -->
                            <ComboBox ItemsSource="{Binding CommonTimes}"
                                      Text="{Binding EditStartTimeText, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Margin="0,0,0,4"/>
                            <!-- 格式錯誤提示 -->
                            <TextBlock Text="{Binding StartTimeError}"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Visibility="{Binding StartTimeError,
                                           Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- 分隔線 -->
                        <ui:TextBlock Grid.Column="1" Text="–"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FontSize="18" Margin="0,8,0,0"/>

                        <!-- 下班時間 -->
                        <StackPanel Grid.Column="2">
                            <ui:TextBlock Text="下班時間 *" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CommonTimes}"
                                      Text="{Binding EditEndTimeText, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding EndTimeError}"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Visibility="{Binding EndTimeError,
                                           Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- 工時顯示 -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="6" Padding="12,8" Margin="0,4,0,20">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Clock24" FontSize="16"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           Margin="0,0,8,0"/>
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13">
                                <Run Text="預計工時："/>
                                <Run Text="{Binding WorkHoursDisplay, Mode=OneWay}"
                                     Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                     FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 代表色選擇 -->
                    <ui:TextBlock Text="代表色" FontTypography="BodyStrong" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding ColorPalette}" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="32" Height="32" CornerRadius="6" Margin="0,0,6,6"
                                        Cursor="Hand"
                                        Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                        BorderThickness="2"
                                        MouseLeftButtonDown="ColorSwatch_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ColorMatchConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.EditColor"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 啟用開關 -->
                    <ui:ToggleSwitch Content="啟用此班別"
                                     IsChecked="{Binding EditIsEnabled}"
                                     Margin="0,0,0,24"/>

                    <!-- 操作按鈕 -->
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="儲存" Icon="{ui:SymbolIcon Symbol=Save24}"
                                    Appearance="Primary" Margin="0,0,8,0"
                                    Command="{Binding SaveCommand}"/>
                        <ui:Button Content="取消" Command="{Binding CancelCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
