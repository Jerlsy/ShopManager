<UserControl x:Class="ShopManager.Views.ShiftSettings.ShiftSettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="28,8,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="28"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="班別設定"
                               FontSize="30"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="為各班別設定打卡時間與識別顏色，排班時可直接套用並快速新增排班"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding StartNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="新增班別"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="18"
                    CornerRadius="28"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="班別列表"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <ListBox ItemsSource="{Binding Shifts}"
                             SelectedItem="{Binding SelectedShift}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        Background="{DynamicResource AppPanelAltBrush}"
                                        CornerRadius="20"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="10"
                                                        Height="10"
                                                        CornerRadius="5"
                                                        Margin="0,0,8,0"
                                                        Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}"/>
                                                <TextBlock Text="{Binding Alias}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"/>
                                                <Border Margin="8,0,0,0"
                                                        Padding="8,2"
                                                        CornerRadius="12"
                                                        Background="{DynamicResource AppInfoBrush}"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                    <TextBlock Text="停用"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{DynamicResource AppSubtleForegroundStrongBrush}">
                                                <Run Text="{Binding StartTime, StringFormat={}{0:HH\\:mm}}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndTime, StringFormat={}{0:HH\\:mm}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding WorkHours, StringFormat={}{0:F1}}"/>
                                                <Run Text=" 小時"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <md:PackIcon Kind="ClockOutline"
                                 Width="64"
                                 Height="64"
                                 Opacity="0.26"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="請點選左側班別，或點選新增班別即可在此編輯"
                               Margin="0,14,0,0"
                               Opacity="0.56"
                               FontSize="15"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Padding="24"
                            CornerRadius="28"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            MaxWidth="620"
                            HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedShift, Converter={StaticResource NullToStringConverter}, ConverterParameter='新增班別|編輯班別'}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18"/>

                            <TextBox md:HintAssist.Hint="班別名稱"
                                     Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="上班時間"
                                               Margin="0,0,0,6"
                                               FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding CommonTimes}"
                                              Text="{Binding EditStartTimeText, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              md:HintAssist.Hint="HH:mm"/>
                                    <TextBlock Text="{Binding StartTimeError}"
                                               Margin="0,6,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                               Visibility="{Binding StartTimeError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="下班時間"
                                               Margin="0,0,0,6"
                                               FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding CommonTimes}"
                                              Text="{Binding EditEndTimeText, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              md:HintAssist.Hint="HH:mm"/>
                                    <TextBlock Text="{Binding EndTimeError}"
                                               Margin="0,6,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                               Visibility="{Binding EndTimeError, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>

                            <Border Padding="14"
                                    Margin="0,0,0,18"
                                    Background="{DynamicResource AppPanelAltBrush}"
                                    CornerRadius="20"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ClockTimeFourOutline"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    <TextBlock>
                                        <Run Text="工作時數:"/>
                                        <Run Text="{Binding WorkHoursDisplay}"
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="選擇顏色"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding ColorPalette}"
                                          Margin="0,0,0,20">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="34"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                CornerRadius="10"
                                                Cursor="Hand"
                                                Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                                BorderThickness="2.5"
                                                MouseLeftButtonDown="ColorSwatch_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource ColorMatchConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.EditColor" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Padding="14"
                                    Margin="0,0,0,20"
                                    Background="{DynamicResource AppPanelAltBrush}"
                                    CornerRadius="20"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1">
                                <DockPanel>
                                    <TextBlock Text="啟用此班別"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton DockPanel.Dock="Right"
                                                  IsChecked="{Binding EditIsEnabled}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                </DockPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Margin="0,0,10,0"
                                        Command="{Binding SaveCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="儲存"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="取消"
                                        Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

