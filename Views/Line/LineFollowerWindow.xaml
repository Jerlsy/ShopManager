<Window x:Class="ShopManager.Views.Line.LineFollowerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ShopManager.ViewModels"
        Title="LINE 推播好友清單"
        Width="500" MinHeight="360" MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{DynamicResource AppFontFamily}"
        FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource AppSurfaceBrush}">

    <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部標頭 -->
        <Border Grid.Row="0" Padding="20,14,20,14"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="MessageTextOutline" Width="18" Height="18"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="LINE 推播好友清單"
                                   FontWeight="SemiBold" FontSize="15"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastSyncText}"
                               FontSize="11"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                               Margin="26,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                        Height="34" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Refresh" Width="15" Height="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="更新"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 主體 -->
        <Border Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}">
            <Grid>
                <!-- 載入中 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <md:PackIcon Kind="Loading" Width="32" Height="32"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="同步中…" Margin="0,8,0,0"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 錯誤訊息 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <md:PackIcon Kind="AlertCircleOutline" Width="36" Height="36"
                                 Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                               Margin="20,8,20,0" MaxWidth="360"/>
                </StackPanel>

                <!-- 空清單提示 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsBusy}" Value="False"/>
                                        <Condition Binding="{Binding HasError}" Value="False"/>
                                        <Condition Binding="{Binding Followers.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="AccountOffOutline" Width="36" Height="36"
                                 Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="目前沒有好友，請點「更新」同步"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                               Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 好友清單 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsBusy}" Value="False"/>
                                        <Condition Binding="{Binding HasError}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Followers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:LineFollowerItem}">
                                <Border Padding="16,10"
                                        Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Margin="8,4,8,0"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 頭像 -->
                                        <Border Grid.Column="0"
                                                Width="38" Height="38" CornerRadius="19"
                                                ClipToBounds="True"
                                                Background="{DynamicResource AppBorderBrush}"
                                                VerticalAlignment="Center">
                                            <Grid>
                                                <Image Stretch="UniformToFill"
                                                       Source="{Binding PictureUrl}"
                                                       Visibility="{Binding PictureUrl, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                <md:PackIcon Kind="Account" Width="22" Height="22"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                             Visibility="{Binding PictureUrl, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                            </Grid>
                                        </Border>

                                        <!-- 名稱 + userId -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding UserId}" FontSize="10"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                       FontFamily="Consolas"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- 右側：綁定狀態 或 選擇按鈕 -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                                            <!-- 綁定 chip（非 Select 模式） -->
                                            <Border CornerRadius="10" Padding="8,3" Margin="0,0,4,0"
                                                    Visibility="{Binding DataContext.IsSelectMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A808080"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActiveBinding}" Value="True">
                                                                <Setter Property="Background" Value="#1A1976D2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDisabledBinding}" Value="True">
                                                                <Setter Property="Background" Value="#1AFF9800"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppSubtleForegroundBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActiveBinding}" Value="True">
                                                                    <Setter Property="Foreground" Value="#1976D2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsDisabledBinding}" Value="True">
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding BoundEmployeeName, TargetNullValue='未綁定'}"/>
                                                    <Run FontSize="10">
                                                        <Run.Style>
                                                            <Style TargetType="Run">
                                                                <Setter Property="Text" Value=""/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDisabledBinding}" Value="True">
                                                                        <Setter Property="Text" Value=" · 已離職"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Run.Style>
                                                    </Run>
                                                </TextBlock>
                                            </Border>

                                            <!-- Select 模式：選擇按鈕 -->
                                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                    Height="30" Padding="10,0" FontSize="12"
                                                    Visibility="{Binding DataContext.IsSelectMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Click="SelectButton_Click"
                                                    Tag="{Binding}">
                                                <TextBlock Text="選擇此帳號"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
