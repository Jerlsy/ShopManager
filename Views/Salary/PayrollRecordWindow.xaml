<Window x:Class="ShopManager.Views.Salary.PayrollRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ShopManager.ViewModels"
        Title="發薪紀錄"
        Width="720" MinHeight="400" MaxHeight="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText"
                       FontSize="{DynamicResource FontSizeDialogTitle}"
                       FontWeight="SemiBold"/>
            <TextBlock Text="確認各員工支薪狀態，並透過 LINE 傳送薪資單"
                       Style="{StaticResource SubtleTextStyle}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 員工清單 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="580">
            <ItemsControl x:Name="EntryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PayrollEntryItem}">
                        <Border Margin="0,0,0,8" Padding="16,12"
                                CornerRadius="12"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 頭像 -->
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                        ClipToBounds="True" VerticalAlignment="Center" Margin="0,0,14,0"
                                        Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                    <Grid>
                                        <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                               Stretch="UniformToFill"
                                               Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Employee.Name, Converter={StaticResource NameInitialConverter}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="17" FontWeight="Bold"
                                                   Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    </Grid>
                                </Border>

                                <!-- 姓名 + 銀行帳戶 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Employee.Name}"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource BodyTextStyle}"/>
                                    <TextBlock Text="{Binding BankSummary}"
                                               Style="{StaticResource SubtleTextStyle}"
                                               FontSize="12" Margin="0,3,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- 金額 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            HorizontalAlignment="Right" Margin="16,0">
                                    <TextBlock Text="{Binding GrandTotal, StringFormat={}{0:N0} 元}"
                                               FontWeight="Bold" FontSize="16"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="應領薪資"
                                               Style="{StaticResource SubtleTextStyle}"
                                               FontSize="11" HorizontalAlignment="Right"/>
                                </StackPanel>

                                <!-- 已支薪 + LINE -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="130">
                                    <CheckBox Content="已支薪"
                                              IsChecked="{Binding IsPaid}"
                                              FontWeight="Medium"/>
                                    <TextBlock Text="{Binding PaidAtLabel}"
                                               Style="{StaticResource SubtleTextStyle}"
                                               FontSize="11" Margin="0,2,0,0"
                                               Visibility="{Binding PaidAtLabel, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <Button Margin="0,6,0,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding SendLineCommand}"
                                            IsEnabled="{Binding IsSending, Converter={StaticResource BoolInverseConverter}}"
                                            Visibility="{Binding CanSendLine, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Padding="8,4" Height="30">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="MessageTextOutline" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="LINE 推播" FontSize="12"
                                                       Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                            <TextBlock Text="傳送中..." FontSize="12"
                                                       Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 頁腳 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="關閉"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
