<UserControl x:Class="ShopManager.Views.Salary.SalaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ShopManager.ViewModels"
             Loaded="UserControl_Loaded">

    <Grid Margin="{DynamicResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 頁首 ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="薪資計算" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="依班表計算員工薪資，支援時薪與月薪兩種制度"
                               Style="{StaticResource SubtleTextStyle}" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox Width="160"
                              ItemsSource="{Binding AvailableSchedules}"
                              SelectedItem="{Binding SelectedScheduleItem}"
                              DisplayMemberPath="Label"
                              md:HintAssist.Hint="選擇班表月份"
                              IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverseConverter}}"
                              Margin="0,0,12,0"/>

                    <Button Content="計算薪資"
                            Command="{Binding CalculateCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,0"/>

                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding OpenPayrollRecordCommand}"
                            IsEnabled="{Binding HasResult}"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CashCheck" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="發薪紀錄"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 主體 ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" MinHeight="300">

            <!-- 載入中 -->
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- 尚未選擇班表 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}"            Value="False"/>
                                    <Condition Binding="{Binding HasResult}"            Value="False"/>
                                    <Condition Binding="{Binding SelectedScheduleItem}" Value="{x:Null}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <md:PackIcon Kind="CashMultiple" Width="64" Height="64"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                <TextBlock Text="請選擇班表月份後點選「計算薪資」" HorizontalAlignment="Center"
                           Style="{StaticResource SubtleTextStyle}" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- 已選月份但尚未計算 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}"            Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasResult}"            Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedScheduleItem}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <md:PackIcon Kind="Calculator" Width="64" Height="64"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                <TextBlock Text="此月份尚無薪資記錄，請點選「計算薪資」開始計算" HorizontalAlignment="Center"
                           Style="{StaticResource SubtleTextStyle}" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- 計算結果 -->
            <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding EmployeeItems}" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EmployeeSalaryItem}">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12"
                                PreviewMouseWheel="EmployeeCard_PreviewMouseWheel">
                            <StackPanel>

                                <!-- ── 卡片標題列 ──────────────────────── -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 頭像 -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                            ClipToBounds="True" Margin="0,0,12,0" VerticalAlignment="Center"
                                            Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                        <Grid>
                                            <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding Employee.Name, Converter={StaticResource NameInitialConverter}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </Grid>
                                    </Border>

                                    <!-- 姓名 + 薪資制度 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Employee.Name}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       FontWeight="SemiBold" Margin="0,0,8,0"/>
                                            <md:PackIcon Kind="AlertCircle" Width="16" Height="16"
                                                         Foreground="OrangeRed" VerticalAlignment="Center"
                                                         ToolTip="低於最低薪資標準"
                                                         Visibility="{Binding IsUnderMinWage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Background="{DynamicResource PrimaryHueLightBrush}"
                                                    CornerRadius="4" Padding="6,1" Margin="0,0,6,0">
                                                <TextBlock FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleTextStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHourly}"  Value="True"><Setter Property="Text" Value="時薪制"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding IsMonthly}" Value="True"><Setter Property="Text" Value="月薪制"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleTextStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHourly}" Value="True">
                                                                <Setter Property="Text" Value="{Binding HourlyRate, StringFormat='平日 {0:N0} 元／時'}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMonthly}" Value="True">
                                                                <Setter Property="Text" Value="{Binding MonthlyBase, StringFormat='底薪 {0:N0} 元'}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 合計 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0">
                                        <TextBlock Text="應領薪資" Style="{StaticResource SubtleTextStyle}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding GrandTotal, StringFormat={}{0:N0} 元}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </StackPanel>

                                    <!-- 展開/收合 -->
                                    <ToggleButton Grid.Column="3" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsExpanded}"
                                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                                  Width="32" Height="32">
                                        <ToggleButton.Content><md:PackIcon Kind="ChevronDown"/></ToggleButton.Content>
                                        <md:ToggleButtonAssist.OnContent><md:PackIcon Kind="ChevronUp"/></md:ToggleButtonAssist.OnContent>
                                    </ToggleButton>
                                </Grid>

                                <!-- ── 明細展開區 ───────────────────────── -->
                                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Margin="0,12,0,0">
                                    <Separator Margin="0,0,0,12"/>

                                    <!-- 薪資明細 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左：工時 -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="工時明細" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Command="{Binding ToggleScheduleDetailCommand}"
                                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                        Width="24" Height="24" Padding="0" ToolTip="查看每日出勤明細">
                                                    <md:PackIcon Kind="CalendarSearch" Width="14" Height="14"/>
                                                </Button>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="平日工時" Style="{StaticResource SubtleTextStyle}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeekdayHours, StringFormat={}{0:N1} hr}" Style="{StaticResource BodyTextStyle}"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="假日工時" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding HasHoliday, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HolidayHours, StringFormat={}{0:N1} hr}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding HasHoliday, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="加班一段（≤2hr）" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding HasOT, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OT1Hours, StringFormat={}{0:N1} hr}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding HasOT, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="加班二段（>2hr）" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding OT2Hours, Converter={StaticResource NonZeroToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OT2Hours, StringFormat={}{0:N1} hr}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding OT2Hours, Converter={StaticResource NonZeroToVisibilityConverter}}"/>

                                                <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,6,0,6"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="總工時" Style="{StaticResource SubtleTextStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TotalHours, StringFormat={}{0:N1} hr}" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold"/>
                                            </Grid>

                                            <!-- 每日出勤明細（折疊區） -->
                                            <Border Margin="0,8,0,0" CornerRadius="8"
                                                    Background="{DynamicResource AppPanelAltBrush}"
                                                    Padding="10,8"
                                                    Visibility="{Binding IsScheduleDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="每日出勤明細" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6"/>
                                                    <ItemsControl ItemsSource="{Binding DailyEntries}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:SalaryDailyEntry}">
                                                                <Grid Margin="0,2,0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="72"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                               Style="{StaticResource SubtleTextStyle}" FontSize="12"/>
                                                                    <Border Grid.Column="1" CornerRadius="3" Padding="4,0" Margin="6,0"
                                                                            Background="{DynamicResource PrimaryHueLightBrush}">
                                                                        <TextBlock Text="{Binding TypeTag}" FontSize="11"
                                                                                   Style="{StaticResource SubtleTextStyle}"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding OverrideAmount, StringFormat={}{0:N0} 元}"
                                                                               Style="{StaticResource SubtleTextStyle}" FontSize="12"
                                                                               HorizontalAlignment="Right"
                                                                               Visibility="{Binding OverrideAmount, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding Hours, StringFormat={}{0:N1} hr}"
                                                                               Style="{StaticResource SubtleTextStyle}" FontSize="12"
                                                                               HorizontalAlignment="Right"
                                                                               Visibility="{Binding OverrideAmount, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- 右：薪資 -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="薪資明細" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 平日薪資（時薪制）或底薪（月薪制）-->
                                                <TextBlock Grid.Row="0" Grid.Column="0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleTextStyle}">
                                                            <Setter Property="Text" Value="底薪"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHourly}" Value="True">
                                                                    <Setter Property="Text" Value="平日薪資"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeekdayPay, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="假日薪資" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding HasHoliday, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HolidayPay, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding HasHoliday, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="加班一段薪資" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding HasOT, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OT1Pay, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding HasOT, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="加班二段薪資" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding OT2Hours, Converter={StaticResource NonZeroToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OT2Pay, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding OT2Hours, Converter={StaticResource NonZeroToVisibilityConverter}}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="替代設定金額" Style="{StaticResource SubtleTextStyle}"
                                                           Visibility="{Binding HasOverride, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding OverridePay, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}"
                                                           Visibility="{Binding HasOverride, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,6,0,6"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="薪資小計" Style="{StaticResource SubtleTextStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BaseAmount, StringFormat={}{0:N0} 元}" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ── 額外項目（獎金 / 扣款） ────────── -->
                                    <Separator Margin="0,8,0,8"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="額外項目（獎金／扣款）" Style="{StaticResource SectionHeaderStyle}"/>
                                        <Button Grid.Column="1" Content="＋ 新增"
                                                Command="{Binding AddBonusCommand}"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Padding="4,0" Height="24"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding BonusItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:BonusLineItem}">
                                                <Grid Margin="0,3,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox Grid.Column="0"
                                                              ItemsSource="{x:Static vm:BonusLineItem.Presets}"
                                                              SelectedItem="{Binding SelectedPreset}"
                                                              DisplayMemberPath="Label"
                                                              md:HintAssist.Hint="類型"
                                                              Margin="0,0,6,0"/>

                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding CustomLabel, UpdateSourceTrigger=PropertyChanged}"
                                                             md:HintAssist.Hint="自訂名稱"
                                                             Margin="0,0,6,0"
                                                             Visibility="{Binding SelectedPreset.Type, Converter={StaticResource BonusTypeToCustomLabelVisibilityConverter}}"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SelectedPreset.Label}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                                               Visibility="{Binding SelectedPreset.Type, Converter={StaticResource BonusTypeToPresetLabelVisibilityConverter}}"/>

                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:G}}"
                                                             md:HintAssist.Hint="金額（負數為扣款）"
                                                             Margin="0,0,6,0"/>

                                                    <Button Grid.Column="3"
                                                            Command="{Binding ConfirmCommand}"
                                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                            Width="28" Height="28" Padding="0"
                                                            Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                            ToolTip="確認並儲存">
                                                        <md:PackIcon Kind="Check" Width="16" Height="16"/>
                                                    </Button>

                                                    <Button Grid.Column="4"
                                                            Command="{Binding DataContext.RemoveBonusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                            Width="28" Height="28" Padding="0">
                                                        <md:PackIcon Kind="Close" Width="16" Height="16"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 合計列 -->
                                    <Separator Margin="0,8,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="應領薪資合計" Style="{StaticResource BodyTextStyle}" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding GrandTotal, StringFormat={}{0:N0} 元}"
                                                   Style="{StaticResource BodyTextStyle}" FontWeight="Bold"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 當月人事費用合計 -->
            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="當月人事費用合計" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                        <TextBlock Text="{Binding EmployeeItems.Count, StringFormat='共 {0} 位員工'}"
                                   Style="{StaticResource SubtleTextStyle}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalPersonnelCost, StringFormat={}{0:N0} 元}"
                               FontSize="{DynamicResource FontSizeDialogTitle}"
                               FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                </Grid>
            </Border>

            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
