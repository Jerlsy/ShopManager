<Window x:Class="ShopManager.Views.ShopSelection.ShopSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ShopManager - 店鋪選取"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{DynamicResource AppFontFamily}"
        FontSize="{DynamicResource FontSizeBody}">

    <Grid x:Name="WindowRoot">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource AppShellGradientStartColor}" Offset="0"/>
                <GradientStop Color="{DynamicResource AppShellGradientMidColor}" Offset="0.55"/>
                <GradientStop Color="{DynamicResource AppShellGradientEndColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="420"
                CornerRadius="16"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 頂部圖示與歡迎文字 -->
                <StackPanel Grid.Row="0">
                    <Border Width="56"
                            Height="56"
                            CornerRadius="14"
                            Background="{DynamicResource AppPanelAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <md:PackIcon Kind="StorefrontOutline"
                                     Width="30"
                                     Height="30"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="歡迎使用 ShopManager"
                               FontSize="{DynamicResource FontSizeSection}"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="請選擇店鋪以進入管理系統"
                               FontSize="{DynamicResource FontSizeBody}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                </StackPanel>

                <!-- 店鋪選取區塊 -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="選取店鋪" FontSize="{DynamicResource FontSizeSmallBody}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12"/>
                    
                    <ComboBox ItemsSource="{Binding Shops}"
                              SelectedItem="{Binding SelectedShop}"
                              DisplayMemberPath="Name"
                             
                              md:HintAssist.Hint="請選擇店鋪..."
                              Margin="0,0,0,16"/>

                    <!-- 僅在選中「新增店鋪」時顯示 -->
                    <Border Background="{DynamicResource AppPanelAltBrush}" 
                            CornerRadius="20" Padding="20" 
                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                            Visibility="{Binding IsNewShopSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="建立新據點" FontSize="{DynamicResource FontSizeSmallBody}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="店鋪名稱 *" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewShopName, UpdateSourceTrigger=PropertyChanged}"
                                    />
                            <TextBlock Text="新店鋪將初始化獨立的員工與排班設定。" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.5" Margin="4,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 進入按鈕 -->
                <Button Grid.Row="4"
                        Content="進入系統管理"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        FontSize="{DynamicResource FontSizeHeading}"
                        FontWeight="Bold"
                        md:ButtonAssist.CornerRadius="14"
                        Command="{Binding EnterCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>