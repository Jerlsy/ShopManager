<ui:FluentWindow x:Class="ShopManager.Views.ShopSelection.ShopSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="店鋪管理系統"
        Width="420" Height="320"
        MinWidth="420" MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="店鋪管理系統"/>

        <StackPanel Grid.Row="1" Margin="36,20,36,32" VerticalAlignment="Center">

            <!-- 標題 -->
            <ui:TextBlock Text="選擇店鋪" FontTypography="Title" Margin="0,0,0,4"/>
            <ui:TextBlock Text="請選擇要進入的店鋪"
                          FontTypography="Body"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Margin="0,0,0,20"/>

            <!-- 店鋪下拉選單 -->
            <ComboBox ItemsSource="{Binding Shops}"
                      SelectedItem="{Binding SelectedShop}"
                      DisplayMemberPath="Name"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,12"/>

            <!-- 新增店鋪名稱輸入（選到「新增」才顯示） -->
            <ui:TextBox PlaceholderText="請輸入店鋪名稱"
                        Text="{Binding NewShopName, UpdateSourceTrigger=PropertyChanged}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,20">
                <ui:TextBox.Style>
                    <Style TargetType="ui:TextBox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNewShopSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:TextBox.Style>
            </ui:TextBox>

            <!-- 登入按鈕 -->
            <ui:Button Content="登入"
                       Appearance="Primary"
                       HorizontalAlignment="Stretch"
                       Command="{Binding EnterCommand}"/>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
