<Window x:Class="ShopManager.Views.ShopSelection.ShopSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ShopManager"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="{DynamicResource AppShellBackgroundBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{md:MaterialDesignFont}"
        FontSize="14">

    <Grid x:Name="WindowRoot">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource AppShellGradientStartColor}" Offset="0"/>
                <GradientStop Color="{DynamicResource AppShellGradientMidColor}" Offset="0.55"/>
                <GradientStop Color="{DynamicResource AppShellGradientEndColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="{Binding ElementName=WindowRoot, Path=ActualWidth, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.7}"
                MinHeight="{Binding ElementName=WindowRoot, Path=ActualHeight, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.7}"
                MaxWidth="{Binding ElementName=WindowRoot, Path=ActualWidth, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.95}"
                MaxHeight="{Binding ElementName=WindowRoot, Path=ActualHeight, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.95}"
                CornerRadius="36"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="32">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <Grid MinWidth="460">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border Width="58"
                                Height="58"
                                CornerRadius="20"
                                Background="#E3EBF3"
                                HorizontalAlignment="Left">
                            <md:PackIcon Kind="StorefrontOutline"
                                         Width="30"
                                         Height="30"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="選擇店鋪"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Margin="0,18,0,6"/>
                        <TextBlock Text="請選擇要進入的店鋪,也可在下方新建一個專屬的店鋪"
                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <ComboBox ItemsSource="{Binding Shops}"
                                  SelectedItem="{Binding SelectedShop}"
                                  DisplayMemberPath="Name"
                                  md:HintAssist.Hint="選擇店鋪"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,0,16"/>

                        <TextBox md:HintAssist.Hint="請輸入新店鋪名稱"
                                 Text="{Binding NewShopName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNewShopSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Border CornerRadius="22"
                                Background="{DynamicResource AppInfoBrush}"
                                Padding="14,12"
                                Margin="0,8,0,0">
                            <TextBlock Text="選擇已存在店鋪,可直接使用原有的所有資料,新建則為全新"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="4"
                            Content="進入系統"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            Command="{Binding EnterCommand}"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>

