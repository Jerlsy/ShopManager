<Window x:Class="ShopManager.Views.EmployeeManagement.AvatarCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="裁剪大頭貼" Width="460" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppSurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Crop area -->
        <Border Grid.Row="0" Margin="20,20,20,0" Background="#1A1A2E" CornerRadius="12" ClipToBounds="True">
            <Canvas x:Name="CropCanvas" Width="400" Height="400"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseDown="CropCanvas_MouseDown"
                    MouseMove="CropCanvas_MouseMove"
                    MouseUp="CropCanvas_MouseUp"
                    MouseLeave="CropCanvas_MouseLeave"
                    MouseWheel="CropCanvas_MouseWheel"
                    HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Image (positioned and scaled via TransformGroup in code-behind) -->
                <Image x:Name="PreviewImage" Stretch="None" IsHitTestVisible="False">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImgScale"/>
                            <TranslateTransform x:Name="ImgTranslate"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <!-- Dark overlay with circular hole -->
                <Path IsHitTestVisible="False" Fill="#AA000000">
                    <Path.Data>
                        <CombinedGeometry GeometryCombineMode="Exclude">
                            <CombinedGeometry.Geometry1>
                                <RectangleGeometry Rect="0,0,400,400"/>
                            </CombinedGeometry.Geometry1>
                            <CombinedGeometry.Geometry2>
                                <EllipseGeometry Center="200,200" RadiusX="120" RadiusY="120"/>
                            </CombinedGeometry.Geometry2>
                        </CombinedGeometry>
                    </Path.Data>
                </Path>

                <!-- Circle outline -->
                <Ellipse Canvas.Left="80" Canvas.Top="80" Width="240" Height="240"
                         Stroke="White" StrokeThickness="2" StrokeDashArray="6,3"
                         Opacity="0.8" IsHitTestVisible="False"/>
            </Canvas>
        </Border>

        <!-- Hint text -->
        <TextBlock Grid.Row="1"
                   Text="拖曳移動 · 滾輪縮放"
                   HorizontalAlignment="Center" Margin="0,8,0,0"
                   Opacity="0.5" FontSize="12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="20,12,20,20">
            <Button Content="取消"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True" Margin="0,0,8,0"/>
            <Button Content="確認裁剪"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
