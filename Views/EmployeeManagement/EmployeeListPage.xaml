<UserControl x:Class="ShopManager.Views.EmployeeManagement.EmployeeListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ShopManager.ViewModels">

    <Grid Margin="28,8,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頁面標題 -->
        <Border Grid.Row="0"
                CornerRadius="20"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="員工資料管理" FontSize="{DynamicResource FontSizePageTitle}" FontWeight="SemiBold"/>
                    <TextBlock Text="管理員工基本資料、聯絡方式、預設班別與排班規則"
                               Margin="0,8,0,0" Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding StartNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="新增員工"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 主區域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 員工列表 -->
            <Border Grid.Column="0"
                    Padding="20"
                    CornerRadius="20"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="員工清單" FontSize="{DynamicResource FontSizeSectionAlt}" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <ListBox ItemsSource="{Binding Employees}"
                             SelectedItem="{Binding SelectedEmployee}"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="20">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16" Background="{DynamicResource AppPanelAltBrush}" CornerRadius="20" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="{DynamicResource FontSizeHeading}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Phone, FallbackValue='未設定電話'}" FontSize="{DynamicResource FontSizeSmallBody}" Opacity="0.6" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 編輯區 -->
            <Grid Grid.Column="2">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <md:PackIcon Kind="AccountEditOutline" Width="80" Height="80" Opacity="0.12" HorizontalAlignment="Center"/>
                    <TextBlock Text="請從左側選擇員工，或點選上方「新增員工」進行編輯" Margin="0,20,0,0" Opacity="0.45" FontSize="{DynamicResource FontSizeHeading}" HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="32"
                            HorizontalAlignment="Stretch">
                        <StackPanel>
                            <!-- 編輯表單內容沿用原邏輯 ... -->
                            <TextBlock Text="{Binding SelectedEmployee, Converter={StaticResource NullToStringConverter}, ConverterParameter='新增員工|編輯員工資料'}"
                                       FontSize="{DynamicResource FontSizeListTitle}" FontWeight="SemiBold" Margin="0,0,0,24"/>

                            <TextBlock Text="基本資料" FontSize="{DynamicResource FontSizeSmallBody}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="姓名 *" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditName}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="身分證字號" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding EditIdNumber}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="聯絡地址" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditAddress}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,16" AcceptsReturn="True" MinHeight="60" VerticalContentAlignment="Top"/>
                            <TextBlock Text="聯繫電話" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditPhone}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/><TextBlock Text="儲存"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="取消" Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>