<UserControl x:Class="ShopManager.Views.EmployeeManagement.EmployeeListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ShopManager.ViewModels">

    <Grid Margin="{StaticResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頁面標題 -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="員工資料管理" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="管理員工基本資料、聯絡方式、預設班別與排班規則"
                               Style="{StaticResource SubtleTextStyle}" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding StartNewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="新增員工"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 主區域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 員工列表 -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="員工清單" Style="{StaticResource SectionTitleStyle}"/>
                    <ListBox ItemsSource="{Binding Employees}"
                             SelectedItem="{Binding SelectedEmployee}"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="20">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource ItemTitleStyle}"/>
                                        <TextBlock Text="{Binding Phone, FallbackValue='未設定電話'}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 編輯區 -->
            <Grid Grid.Column="2">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <md:PackIcon Kind="AccountEditOutline" Width="80" Height="80" Opacity="0.12" HorizontalAlignment="Center"/>
                    <TextBlock Text="請從左側選擇員工，或點選上方「新增員工」進行編輯" Margin="0,20,0,0" Opacity="0.45" Style="{StaticResource ItemTitleStyle}" HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource EditFormCardStyle}" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedEmployee, Converter={StaticResource NullToStringConverter}, ConverterParameter='新增員工|編輯員工資料'}"
                                       FontSize="{DynamicResource FontSizeListTitle}" FontWeight="SemiBold" Margin="0,0,0,24"/>

                            <TextBlock Text="基本資料" Style="{StaticResource FormSectionStyle}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="姓名 *" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding EditName}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="身分證字號" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding EditIdNumber}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="聯絡地址" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditAddress}" Margin="0,0,0,16" AcceptsReturn="True" MinHeight="60" VerticalContentAlignment="Top"/>
                            <TextBlock Text="聯繫電話" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditPhone}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/><TextBlock Text="儲存"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="取消" Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>