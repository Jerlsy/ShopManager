<UserControl x:Class="ShopManager.Views.EmployeeManagement.EmployeeListPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:vm="clr-namespace:ShopManager.ViewModels">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 標題列 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="員工資料管理"
                       FontSize="30" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                   
                    HorizontalAlignment="Right"
                    Command="{Binding StartNewCommand}"
                    Visibility="{Binding IsEditing,
                        Converter={StaticResource BoolToVisibilityConverter},
                        ConverterParameter=Inverse}">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="AccountPlus" Width="16" Height="16" Margin="0,0,6,0"/>
                    <TextBlock Text="新增員工" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- 主區域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsEditing,
                    Converter={StaticResource BoolToGridLengthConverter},
                    ConverterParameter=520|0}"/>
            </Grid.ColumnDefinitions>

            
            <!-- 卡片清單                                     -->
            
            <ScrollViewer Grid.Column="0" Padding="0,0,8,0">
                <StackPanel>
                    <!-- 空狀態 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,60,0,0"
                                Visibility="{Binding Employees.Count,
                                    Converter={StaticResource ZeroToVisibilityConverter}}">
                        <md:PackIcon Kind="AccountGroup" Width="60" Height="60"
                                     HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="尚無員工資料，點選右上角「新增員工」開始建立"
                                   FontSize="14" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                   Opacity="0.55"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 員工卡片 -->
                                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="24" Width="230" Margin="0,0,12,12"
                                         Padding="16">
                                    <StackPanel>
                                        <!-- 頭像 + 姓名 -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="44" Height="44" CornerRadius="22"
                                                    Background="{DynamicResource PrimaryHueMidBrush}"
                                                    Margin="0,0,10,0">
                                                <TextBlock
                                                    Text="{Binding Name, Converter={StaticResource NameInitialConverter}}"
                                                    Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="20" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="15"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- 已離職標記 -->
                                                <Border Visibility="{Binding IsResigned,
                                                            Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Background="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                        CornerRadius="10" Padding="6,1" Margin="0,3,0,0"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="已離職" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Separator Margin="0,0,0,8"/>

                                        <!-- 資訊列 -->
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <md:PackIcon Grid.Column="0" Kind="Phone" Width="13" Height="13"
                                                         Opacity="0.55" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Phone, FallbackValue='�'}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Opacity="0.65"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <md:PackIcon Grid.Column="0" Kind="ClockOutline" Width="13" Height="13"
                                                         Opacity="0.55" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DefaultShift.Alias, FallbackValue='未設定班別'}"
                                                       FontSize="12" Opacity="0.65"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <md:PackIcon Grid.Column="0" Kind="CurrencyUsd" Width="13" Height="13"
                                                         Opacity="0.55" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DefaultSalary.Alias, FallbackValue='未設定薪資'}"
                                                       FontSize="12" Opacity="0.65"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <md:PackIcon Grid.Column="0" Kind="CalendarClock" Width="13" Height="13"
                                                         Opacity="0.55" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding HireDate, StringFormat=到職：{0:yyyy/MM/dd}}"
                                                       FontSize="12" Opacity="0.65"/>
                                        </Grid>

                                        <!-- 操作按鈕 -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                   
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.StartEditCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="Pencil" Width="14" Height="14" Margin="0,0,4,0"/>
                                                    <TextBlock Text="編輯" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                    Command="{Binding DataContext.DeleteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            
            <!-- 編輯側欄                                     -->
            
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding IsEditing,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="24" Padding="24" Margin="8,0,0,0">
                    <StackPanel>

                        <!-- 標題 -->
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedEmployee,
                                           Converter={StaticResource NullToStringConverter},
                                           ConverterParameter='新增員工|編輯員工資料'}"
                                       FontSize="24" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CancelCommand}">
                                <md:PackIcon Kind="Close" Width="18" Height="18"/>
                            </Button>
                        </DockPanel>

                        
                        <!-- ║ 1. 基本資料                  ║ -->
                        
                        <TextBlock Text="基本資料"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,6,0"
                                     md:HintAssist.Hint="姓名 *"
                                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <TextBox Grid.Column="1" Margin="6,0,0,0"
                                     md:HintAssist.Hint="身分證字號"
                                     Text="{Binding EditIdNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </Grid>

                        <TextBox md:HintAssist.Hint="聯絡地址"
                                 Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>
                        <TextBox md:HintAssist.Hint="聯繫電話"
                                 Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,10"/>

                        <!-- 通訊軟體 -->
                        <TextBlock Text="通訊軟體（限一組）"
                                   FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                   Margin="0,0,0,4" Opacity="0.7"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                      ItemsSource="{Binding MessengerTypes}"
                                      SelectedItem="{Binding EditMessengerType}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      md:HintAssist.Hint="類型"/>
                            <TextBox Grid.Column="1"
                                     md:HintAssist.Hint="帳號 / ID"
                                     Text="{Binding EditMessengerValue, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </Grid>

                        <!-- 自訂聯絡方式 -->
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="自訂聯絡方式"
                                       FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                       Opacity="0.7" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    HorizontalAlignment="Right"
                                   
                                    Command="{Binding AddCustomContactCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="新增" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding EditCustomContacts}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0"
                                                 md:HintAssist.Hint="名稱（自訂）"
                                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        <TextBox Grid.Column="1" Margin="0,0,6,0"
                                                 md:HintAssist.Hint="值"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                Command="{Binding DataContext.RemoveCustomContactCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,0,0,16"/>

                        
                        <!-- ║ 2. 排班設定                  ║ -->
                        
                        <TextBlock Text="排班設定"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <ComboBox ItemsSource="{Binding AvailableShifts}"
                                          SelectedItem="{Binding EditDefaultShift}"
                                          DisplayMemberPath="Alias"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          md:HintAssist.Hint="預設班別"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <ComboBox ItemsSource="{Binding AvailableSalaries}"
                                          SelectedItem="{Binding EditDefaultSalary}"
                                          DisplayMemberPath="Alias"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          md:HintAssist.Hint="薪資類型"/>
                            </StackPanel>
                        </Grid>

                        <!-- InfoBar -->
                        <Border Background="{DynamicResource PrimaryHueLightBrush}"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="預設班別與薪資僅作為預設值，排班與計薪時可個別調整。"
                                           FontSize="12"
                                           Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 排班規則 Expander -->
                        <Expander Header="排班規則（選填）" IsExpanded="False"
                                  Style="{StaticResource MaterialDesignExpander}"
                                  Margin="0,0,0,16">
                            <StackPanel Margin="0,12,0,4">

                                <!-- 固定休假 -->
                                <TextBlock Text="固定休假日"
                                           FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding FixedOffDayItems}" Margin="0,0,0,16">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:DayOfWeekItem}">
                                            <CheckBox Content="{Binding Label}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="0,0,12,6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 排除班別 -->
                                <TextBlock Text="排除班別"
                                           FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="排班時不排入以下班別"
                                           FontSize="11" Opacity="0.55" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ExcludeShiftItems}" Margin="0,0,0,16">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ShiftCheckItem}">
                                            <CheckBox Content="{Binding Alias}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="0,0,12,6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 不與共事 -->
                                <TextBlock Text="不與共事"
                                           FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="同一班次中避免與以下員工同時排班"
                                           FontSize="11" Opacity="0.55" Margin="0,0,0,8"/>
                                <TextBlock Text="（目前無其他在職員工）"
                                           FontSize="12" FontStyle="Italic" Opacity="0.45"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding NotWithItems.Count,
                                               Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding NotWithItems}" Margin="0,0,0,4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ColleagueCheckItem}">
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="0,0,12,6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Expander>

                        <!-- 預設獎金 -->
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="預設獎金（選填）"
                                       FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                       Opacity="0.7" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    HorizontalAlignment="Right"
                                   
                                    Command="{Binding AddBonusCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="新增" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding EditDefaultBonuses}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0"
                                                 md:HintAssist.Hint="獎金名稱"
                                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        <TextBox Grid.Column="1" Margin="0,0,6,0"
                                                 md:HintAssist.Hint="金額（元）"
                                                 Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                Command="{Binding DataContext.RemoveBonusCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,0,0,16"/>

                        
                        <!-- ║ 3. 任職資料                  ║ -->
                        
                        <TextBlock Text="任職資料"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="到職日 *"
                                           FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                           Margin="0,0,0,4" Opacity="0.7"/>
                                <DatePicker SelectedDate="{Binding EditHireDate,
                                                Converter={StaticResource DateOnlyConverter}}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="離職日（留空 = 在職）"
                                           FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                           Margin="0,0,0,4" Opacity="0.7"/>
                                <DatePicker SelectedDate="{Binding EditResignDate,
                                                Converter={StaticResource NullableDateOnlyConverter}}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 排班衝突警告 -->
                        <Border Visibility="{Binding HasConflicts,
                                    Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                Opacity="0.9"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="離職日之後仍有排班資料，請重新編輯以下月份的班表："
                                           Foreground="White" TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ConflictMonths}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold" Margin="0,2,0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 操作按鈕 -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                   
                                    Margin="0,0,8,0"
                                    Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="儲存" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                   
                                    Content="取消" Margin="0,0,8,0"
                                    Command="{Binding CancelCommand}"/>
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                   
                                    Visibility="{Binding HasConflicts,
                                        Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding ForceSaveCommand}"
                                    ToolTip="忽略排班衝突，強制儲存離職日">
                                <TextBlock Text="強制儲存"/>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>







