<UserControl x:Class="ShopManager.Views.Schedule.SchedulePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ShopManager.ViewModels"
             xmlns:models="clr-namespace:ShopManager.Models"
             Focusable="True">

    <UserControl.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <!-- EntryItem 右鍵選單：透過 PlacementTarget.Tag 取得 ViewModel；x:Shared=False 確保多個 EntryItem 可共用同一資源 -->
        <ContextMenu x:Key="EntryItemContextMenu" x:Shared="False">
            <MenuItem Header="編輯排班"
                      Command="{Binding PlacementTarget.Tag.OpenEditEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext.EntryId, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <md:PackIcon Kind="Pencil"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="複製到下週"
                      Command="{Binding PlacementTarget.Tag.CopyToNextWeekCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext.EntryId, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <md:PackIcon Kind="ContentCopy"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="從班表移除"
                      Command="{Binding PlacementTarget.Tag.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext.EntryId, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <md:PackIcon Kind="DeleteOutline" Foreground="#E53935"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="{DynamicResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頁面標題列 -->
        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="8" ClipToBounds="True" Margin="0,0,16,0"
                            Visibility="{Binding DataContext.ShopLogoData, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NullToVisibilityConverter}}">
                        <Image Source="{Binding DataContext.ShopLogoData, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="排班管理" Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 月份導覽 -->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,6,0" Command="{Binding PreviousMonthCommand}">
                        <md:PackIcon Kind="ChevronLeft"/>
                    </Button>
                    <TextBlock Text="{Binding CalendarTitle}" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeHeading}" FontWeight="Bold" Margin="0,0,6,0"
                               MinWidth="120" TextAlignment="Center"/>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,12,0" Command="{Binding NextMonthCommand}">
                        <md:PackIcon Kind="ChevronRight"/>
                    </Button>

                    <!-- 視圖模式切換 -->
                    <Border CornerRadius="16" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                            Background="{DynamicResource AppPanelAltBrush}" Margin="0,0,10,0" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="月" GroupName="ViewMode" Margin="2,0"
                                         IsChecked="{Binding IsMonthView, Mode=OneWay}"
                                         Command="{Binding SetMonthViewCommand}"
                                         Style="{StaticResource MaterialDesignTabRadioButton}"/>
                            <RadioButton Content="周" GroupName="ViewMode" Margin="2,0"
                                         IsChecked="{Binding IsWeekView, Mode=OneWay}"
                                         Command="{Binding SetWeekViewCommand}"
                                         Style="{StaticResource MaterialDesignTabRadioButton}"/>
                            <RadioButton Content="日" GroupName="ViewMode" Margin="2,0"
                                         IsChecked="{Binding IsDayView, Mode=OneWay}"
                                         Command="{Binding SetDayViewCommand}"
                                         Style="{StaticResource MaterialDesignTabRadioButton}"/>
                        </StackPanel>
                    </Border>

                    <!-- 衝突徽章 -->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CheckConflictsCommand}"
                            Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0" Padding="8,0"
                            Foreground="#E53935" BorderBrush="#E53935">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AlertCircleOutline" Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{Binding ConflictCount, Mode=OneWay}"/>
                                <Run Text=" 條衝突"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- 空班別徽章 -->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CheckConflictsCommand}"
                            Visibility="{Binding HasEmptyShifts, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,8,0" Padding="8,0"
                            ToolTip="班別尚未排入任何員工"
                            Foreground="#F57C00" BorderBrush="#F57C00">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CalendarAlert" Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{Binding EmptyShiftTotalCount, Mode=OneWay}"/>
                                <Run Text=" 個空班"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- 還原 -->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}"
                            ToolTip="{Binding UndoDescription}"
                            Width="40" Height="36" Padding="0"
                            Margin="0,0,8,0">
                        <md:PackIcon Kind="UndoVariant" Width="18" Height="18"/>
                    </Button>

                    <!-- 新增班表 -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding StartCreateScheduleCommand}"
                            Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CalendarPlus" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="新增班表"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding StartCreateScheduleCommand}"
                            Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="重新建立本月班表"
                            Margin="0,0,8,0">
                        <md:PackIcon Kind="CalendarRefresh" Width="18" Height="18"/>
                    </Button>
                    <!-- 自動排班 -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding StartAutoAssignCommand}"
                            Visibility="{Binding ShowAutoAssignButton, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AutoFix" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="自動排班"/>
                        </StackPanel>
                    </Button>

                    <!-- 轉存班表 -->
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="ExportSchedule_Click"
                            Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="8,0,0,0" ToolTip="將本月班表匯出為 PNG 圖片">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileExportOutline" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="轉存班表"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- 主排班區 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 多選浮動工具列 -->
            <Border Grid.ColumnSpan="3" Panel.ZIndex="50"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,12,0,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="#1976D2" BorderThickness="1.5"
                    CornerRadius="20" Padding="14,8"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="CheckCircle" Width="18" Height="18"
                                 Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                        <Run Text="已選 "/>
                        <Run Text="{Binding SelectionCount, Mode=OneWay}"/>
                        <Run Text=" 筆"/>
                    </TextBlock>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding DeleteSelectedCommand}"
                            Margin="14,0,0,0" Padding="10,0" Height="30"
                            Foreground="#E53935" BorderBrush="#E53935">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DeleteOutline" Width="15" Height="15" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="批次刪除" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding ClearSelectionCommand}"
                            ToolTip="取消選取" Width="30" Height="30" Padding="0" Margin="6,0,0,0">
                        <md:PackIcon Kind="Close" Width="15" Height="15"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 左側員工列表 (支援拖曳) -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}"
                    PreviewMouseWheel="Section_PreviewMouseWheel">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="員工清單" Style="{StaticResource SectionTitleStyle}"/>
                    <ListBox x:Name="EmployeeList" ItemsSource="{Binding EmployeeWorkloads}" Background="Transparent"
                             BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EmployeeWorkloadItem}">
                                <Border Style="{StaticResource ItemCardStyle}" CornerRadius="16" Margin="0,0,0,8" Padding="10,8"
                                        PreviewMouseLeftButtonDown="Employee_PreviewMouseLeftButtonDown"
                                        MouseMove="Employee_MouseMove"
                                        MouseLeftButtonUp="Employee_MouseLeftButtonUp"
                                        Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True" Margin="0,0,10,0"
                                                Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                            <Grid>
                                                <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                           FontSize="13" FontWeight="Bold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" MinWidth="0">
                                            <TextBlock Text="{Binding Employee.Name}" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="10" Margin="0,2,0,0"
                                                       Visibility="{Binding HasTarget, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnder}" Value="True">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOver}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="已排 "/>
                                                <Run Text="{Binding ShiftCount, Mode=OneWay}"/>
                                                <Run Text=" / 可排 "/>
                                                <Run Text="{Binding TargetCount, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右側行事曆 -->
            <Border Grid.Column="2"
                    CornerRadius="20"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    Padding="8"
                    PreviewMouseWheel="Section_PreviewMouseWheel">
                <Grid>
                    <!-- 行事曆（非建立/自動排班模式） -->
                    <Grid Visibility="{Binding IsViewingCalendar, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- ═══ 月視圖 ═══ -->
                        <Grid Visibility="{Binding IsMonthView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 星期標題列 -->
                            <Grid Grid.Row="0" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding DayHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                       Padding="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- 周列 -->
                            <ScrollViewer x:Name="MonthScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding CalendarWeeks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CalendarWeekRow}">
                                            <Grid MinHeight="90" Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- 第幾周 -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding WeekNumber}"
                                                           VerticalAlignment="Top"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,10,0,0"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"/>

                                                <!-- 7 個日格 -->
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1" Columns="7"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:CalendarDay}">
                                                            <Border Margin="2,1" CornerRadius="8"
                                                                    BorderThickness="1"
                                                                    MouseLeftButtonDown="CalendarDay_Click">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                                                                        <Setter Property="Cursor" Value="Hand"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                                                <Setter Property="Cursor" Value="Arrow"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                                                <Setter Property="Background" Value="#1A808080"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasStaffingGap}" Value="True">
                                                                                <Setter Property="Effect">
                                                                                    <Setter.Value>
                                                                                        <DropShadowEffect Color="#FF9800" BlurRadius="10" ShadowDepth="0" Opacity="0.75"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>

                                                                <Grid Margin="5,4">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>

                                                                    <!-- 日期數字 -->
                                                                    <TextBlock Grid.Row="0"
                                                                               Text="{Binding Day}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                                               Margin="0,0,0,2">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource AppSubtleForegroundBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>

                                                                    <!-- 班別色塊 -->
                                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ShiftBlocks}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type vm:ShiftBlock}">
                                                                                <Border CornerRadius="3" Padding="4,1" Margin="0,0,2,2"
                                                                                        Tag="{Binding}"
                                                                                        AllowDrop="True"
                                                                                        DragOver="ShiftBlock_DragOver"
                                                                                        Drop="ShiftBlock_Drop"
                                                                                        ToolTipOpening="ShiftBlock_ToolTipOpening"
                                                                                        Background="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                                                    <Setter Property="Opacity" Value="0.35"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <Border.ToolTip>
                                                                                        <ToolTip Style="{StaticResource SpeechBubbleToolTip}">
                                                                                            <Grid>
                                                                                                <StackPanel Orientation="Horizontal"
                                                                                                            Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                                                    <md:PackIcon Kind="Cancel" Width="15" Height="15" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                                    <TextBlock Text="{Binding DisabledReason}" Foreground="#C62828" FontWeight="SemiBold" FontSize="13"/>
                                                                                                </StackPanel>
                                                                                                <StackPanel MinWidth="120"
                                                                                                            Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                                                                Background="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                                                            <TextBlock Text="{Binding ShiftSetting.Alias}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                                                                                        </Border>
                                                                                                        <TextBlock Text="{Binding ShiftSetting.Name}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                                    </StackPanel>
                                                                                                    <ItemsControl ItemsSource="{Binding EntryItems}">
                                                                                                        <ItemsControl.ItemTemplate>
                                                                                                            <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                                                    <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True" Margin="0,0,6,0"
                                                                                                                            Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                                                                                        <Grid>
                                                                                                                            <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"
                                                                                                                                   Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                                                            <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                                                                       FontSize="9" FontWeight="Bold" Foreground="White"
                                                                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                                                        </Grid>
                                                                                                                    </Border>
                                                                                                                    <TextBlock Text="{Binding Employee.Name}" FontSize="12" VerticalAlignment="Center"/>
                                                                                                                </StackPanel>
                                                                                                            </DataTemplate>
                                                                                                        </ItemsControl.ItemTemplate>
                                                                                                    </ItemsControl>
                                                                                                    <TextBlock Text="（尚無排班）" FontSize="11" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                                                               Visibility="{Binding EntryItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                                                                                </StackPanel>
                                                                                            </Grid>
                                                                                        </ToolTip>
                                                                                    </Border.ToolTip>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="{Binding ShiftSetting.Alias, Mode=OneWay}"
                                                                                                   FontSize="10" Foreground="White" FontWeight="Medium"/>
                                                                                        <TextBlock FontSize="10" Foreground="White" Margin="2,0,0,0"
                                                                                                   Visibility="{Binding EntryItems.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                                                                                            <Run Text="×"/>
                                                                                            <Run Text="{Binding EntryItems.Count, Mode=OneWay}"/>
                                                                                        </TextBlock>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <!-- 空班別警示（紅點 badge，數字表示空班數）-->
                                                                    <Border Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                            CornerRadius="7" Padding="4,1" Background="#F57C00"
                                                                            ToolTip="此日有班別尚未排入員工" Cursor="Help"
                                                                            Visibility="{Binding HasEmptyShifts, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <md:PackIcon Kind="CalendarAlert" Width="9" Height="9" Foreground="White" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding EmptyShiftCount}" FontSize="9" FontWeight="Bold"
                                                                                       Foreground="White" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <!-- 人力不足警示 -->
                                                                    <Border Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                            ToolTip="自動排班後人力不足" Cursor="Help" Background="Transparent"
                                                                            Visibility="{Binding HasStaffingGap, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <md:PackIcon Kind="AccountAlertOutline" Width="11" Height="11" Foreground="#FF9800"/>
                                                                    </Border>

                                                                    <!-- 國定假日浮水印 -->
                                                                    <TextBlock Grid.Row="2"
                                                                               Text="{Binding HolidayName}"
                                                                               HorizontalAlignment="Right"
                                                                               FontSize="9"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{Binding HolidayName, Converter={StaticResource NullToVisibilityConverter}}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Opacity" Value="0.4"/>
                                                                                <Setter Property="FontSize" Value="9"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppSubtleForegroundBrush}"/>
                                                                                <Setter Property="Cursor" Value="Help"/>
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Opacity" Value="1"/>
                                                                                        <Setter Property="FontSize" Value="13.5"/>
                                                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                        <TextBlock.ToolTip>
                                                                            <ToolTip Padding="0" Background="Transparent" BorderThickness="0" HasDropShadow="True">
                                                                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                                                                        BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="10"
                                                                                        Padding="14,10">
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <md:PackIcon Kind="CalendarStar"
                                                                                                     Width="18" Height="18"
                                                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                                                     VerticalAlignment="Center"
                                                                                                     Margin="0,0,10,0"/>
                                                                                        <TextBlock Text="{Binding HolidayName}"
                                                                                                   FontSize="14"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{DynamicResource AppForegroundBrush}"
                                                                                                   VerticalAlignment="Center"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </ToolTip>
                                                                        </TextBlock.ToolTip>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- ═══ 周視圖 ═══ -->
                        <Grid Visibility="{Binding IsWeekView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 日期標題 -->
                            <Grid Grid.Row="0" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding CalendarDays}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Rows="1" Columns="7"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CalendarDay}">
                                            <Border Padding="4" MouseLeftButtonDown="WeekDayHeader_Click" Cursor="Hand">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DayOfWeekText}" FontWeight="SemiBold" TextAlignment="Center"
                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding Day}" TextAlignment="Center" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Border VerticalAlignment="Center" Margin="3,0,0,0" Background="Transparent"
                                                                ToolTip="自動排班後人力不足" Cursor="Help"
                                                                Visibility="{Binding HasStaffingGap, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <md:PackIcon Kind="AccountAlertOutline" Width="11" Height="11" Foreground="#FF9800"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- 時間格線 + 班別長條 -->
                            <ScrollViewer x:Name="WeekScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 時間標籤 -->
                                    <ItemsControl Grid.Column="0" ItemsSource="{Binding TimeSlots}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:CalendarTimeSlot}">
                                                <TextBlock Text="{Binding Label}" Height="60"
                                                           VerticalAlignment="Top" HorizontalAlignment="Right"
                                                           Margin="0,2,8,0" FontSize="10"
                                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 7 天欄位 -->
                                    <Grid Grid.Column="1" Height="{Binding TimeGridHeight}">
                                        <!-- 格線背景 -->
                                        <ItemsControl ItemsSource="{Binding TimeSlots}" IsHitTestVisible="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Height="60" VerticalAlignment="Top"
                                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 天欄覆蓋層 -->
                                        <ItemsControl ItemsSource="{Binding CalendarDays}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Rows="1" Columns="7"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:CalendarDay}">
                                                    <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                                        <Setter Property="Background" Value="#10808080"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOutOfScope}" Value="True">
                                                                        <Setter Property="Background" Value="#20808080"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasStaffingGap}" Value="True">
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#FF9800" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <!-- 班別長條 -->
                                                        <ItemsControl ItemsSource="{Binding ShiftBlocks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemContainerStyle>
                                                                <Style TargetType="ContentPresenter">
                                                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                                                    <Setter Property="Margin" Value="{Binding BlockMargin}"/>
                                                                    <Setter Property="Height" Value="{Binding BlockHeight}"/>
                                                                </Style>
                                                            </ItemsControl.ItemContainerStyle>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:ShiftBlock}">
                                                                    <Border CornerRadius="6"
                                                                            Tag="{Binding}"
                                                                            AllowDrop="True"
                                                                            DragOver="ShiftBlock_DragOver"
                                                                            Drop="ShiftBlock_Drop"
                                                                            ToolTipOpening="ShiftBlock_ToolTipOpening"
                                                                            ClipToBounds="True">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}"/>
                                                                                <Setter Property="BorderBrush"     Value="Transparent"/>
                                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                                        <Setter Property="Opacity" Value="0.35"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                                        <Setter Property="Opacity"         Value="0.55"/>
                                                                                        <Setter Property="BorderBrush"     Value="#F57C00"/>
                                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Border.ToolTip>
                                                                            <ToolTip Style="{StaticResource SpeechBubbleCustomToolTip}">
                                                                                <Grid>
                                                                                    <StackPanel Orientation="Horizontal"
                                                                                                Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                                        <md:PackIcon Kind="Cancel" Width="15" Height="15" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                                        <TextBlock Text="{Binding DisabledReason}" Foreground="#C62828" FontWeight="SemiBold" FontSize="13"/>
                                                                                    </StackPanel>
                                                                                    <StackPanel MinWidth="120" Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                                                    Background="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                                                <TextBlock Text="{Binding ShiftSetting.Alias}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                                                                            </Border>
                                                                                            <TextBlock Text="{Binding ShiftSetting.Name}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                                        </StackPanel>
                                                                                        <ItemsControl ItemsSource="{Binding EntryItems}">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                                        <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True" Margin="0,0,6,0"
                                                                                                                Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                                                                            <Grid>
                                                                                                                <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"
                                                                                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                                                <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                                                           FontSize="9" FontWeight="Bold" Foreground="White"
                                                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                                            </Grid>
                                                                                                        </Border>
                                                                                                        <TextBlock Text="{Binding Employee.Name}" FontSize="12" VerticalAlignment="Center"/>
                                                                                                    </StackPanel>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                        <TextBlock Text="（尚無排班）" FontSize="11" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                                                   Visibility="{Binding EntryItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </ToolTip>
                                                                        </Border.ToolTip>
                                                                        <Grid Margin="6,5,6,5">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="*"/>
                                                                            </Grid.RowDefinitions>
                                                                            <TextBlock Grid.Row="0" Text="{Binding ShiftSetting.Alias}"
                                                                                       FontSize="11" Foreground="White" FontWeight="Bold"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Grid.Row="1" FontSize="10" Foreground="White" Opacity="0.85"
                                                                                       TextTrimming="CharacterEllipsis">
                                                                                <Run Text="{Binding ShiftSetting.StartTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                                <Run Text="–"/>
                                                                                <Run Text="{Binding ShiftSetting.EndTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                            </TextBlock>
                                                                            <!-- 員工縮圖 + 姓名 -->
                                                                            <ItemsControl Grid.Row="2" ItemsSource="{Binding EntryItems}" Margin="0,4,0,0">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <StackPanel Orientation="Vertical"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3"
                                                                                                    PreviewMouseLeftButtonDown="EntryRow_PreviewMouseLeftButtonDown"
                                                                                                    MouseMove="EntryRow_MouseMove"
                                                                                                    MouseLeftButtonUp="EntryRow_MouseLeftButtonUp"
                                                                                                    Cursor="Hand"
                                                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                                    ContextMenu="{StaticResource EntryItemContextMenu}">
                                                                                            <StackPanel.Style>
                                                                                                <Style TargetType="StackPanel">
                                                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                            <Setter Property="Background" Value="#552196F3"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </StackPanel.Style>
                                                                                            <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True"
                                                                                                    Margin="0,0,5,0" BorderThickness="1.5" BorderBrush="White"
                                                                                                    Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                                                    AllowDrop="True"
                                                                                                    DragOver="EntryChip_DragOver"
                                                                                                    Drop="EntryChip_Drop">
                                                                                                <Grid>
                                                                                                    <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                                                                           Stretch="UniformToFill"
                                                                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                                    <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                               Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                                </Grid>
                                                                                            </Border>
                                                                                            <TextBlock Text="{Binding Employee.Name}" FontSize="11" Foreground="White"
                                                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <!-- ═══ 日視圖 ═══ -->
                        <Grid Visibility="{Binding IsDayView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 日期標題列 -->
                            <Border Grid.Row="0" Padding="8,10"
                                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"
                                    Margin="0,0,0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DayViewDay.HasStaffingGap}" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FF9800" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DayViewDay.DayOfWeekText}"
                                                   FontWeight="SemiBold" Margin="0,0,6,0"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                   FontSize="{DynamicResource FontSizeSmall}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock FontWeight="Bold" FontSize="{DynamicResource FontSizeSubTitle}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DayViewDay.IsToday}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding DayViewDay.Day, Mode=OneWay}"/><Run Text=" 日"/>
                                        </TextBlock>
                                        <Border CornerRadius="8" Padding="8,2" Margin="10,0,0,0"
                                                Background="#1A808080"
                                                Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="店休" FontSize="{DynamicResource FontSizeSmall}"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                        </Border>
                                        <Border VerticalAlignment="Center" Margin="10,0,0,0" Background="Transparent"
                                                ToolTip="自動排班後人力不足" Cursor="Help"
                                                Visibility="{Binding DayViewDay.HasStaffingGap, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <md:PackIcon Kind="AccountAlertOutline" Width="16" Height="16" Foreground="#FF9800"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- 設為店休日（上班日時顯示） -->
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding SetDayViewDayClosedCommand}"
                                                Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                                Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12"
                                                Foreground="#E53935" BorderBrush="#E53935">
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="StoreOff" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="設為店休日" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- 設為上班日（店休時顯示） -->
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding SetDayViewDayOpenCommand}"
                                                Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12">
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="Store" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="設為上班日" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- 調整班別（上班日時顯示） -->
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding OpenShiftOverrideForDayViewCommand}"
                                                Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                                Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12">
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="CalendarEdit" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="調整班別" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- 排班明細浮層 -->
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding OpenDayDetailCommand}"
                                                CommandParameter="{Binding DayViewDay}"
                                                Height="32" Padding="10,0" FontSize="12">
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="ViewList" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="排班明細" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 時間內容 -->
                            <Grid Grid.Row="1">
                                <!-- 店休訊息 -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <md:PackIcon Kind="StoreOff" Width="48" Height="48" HorizontalAlignment="Center"
                                                 Foreground="{DynamicResource AppSubtleForegroundBrush}" Opacity="0.45" Margin="0,0,0,12"/>
                                    <TextBlock Text="今日店休" FontSize="{DynamicResource FontSizeSubTitle}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AppSubtleForegroundBrush}" Opacity="0.6"/>
                                </StackPanel>

                                <!-- 時間表格 -->
                                <ScrollViewer x:Name="DayScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding DayViewDayIsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 時間標籤 -->
                                        <ItemsControl Grid.Column="0" ItemsSource="{Binding TimeSlots}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:CalendarTimeSlot}">
                                                    <TextBlock Text="{Binding Label}" Height="60"
                                                               VerticalAlignment="Top" HorizontalAlignment="Right"
                                                               Margin="0,2,12,0" FontSize="12"
                                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 單日欄 -->
                                        <Grid Grid.Column="1" Height="{Binding TimeGridHeight}">
                                    <!-- 格線背景 -->
                                    <ItemsControl ItemsSource="{Binding TimeSlots}" IsHitTestVisible="False">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="60" VerticalAlignment="Top"
                                                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 班別長條 -->
                                    <ItemsControl ItemsSource="{Binding DayViewDay.ShiftBlocks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="VerticalAlignment" Value="Top"/>
                                                <Setter Property="Margin" Value="{Binding BlockMargin}"/>
                                                <Setter Property="Height" Value="{Binding BlockHeight}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ShiftBlock}">
                                                <Border CornerRadius="8"
                                                        Tag="{Binding}"
                                                        AllowDrop="True"
                                                        DragOver="ShiftBlock_DragOver"
                                                        Drop="ShiftBlock_Drop"
                                                        ToolTipOpening="ShiftBlock_ToolTipOpening"
                                                        ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}"/>
                                                            <Setter Property="BorderBrush"     Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.35"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                    <Setter Property="Opacity"         Value="0.55"/>
                                                                    <Setter Property="BorderBrush"     Value="#F57C00"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.ToolTip>
                                                        <ToolTip Style="{StaticResource SpeechBubbleCustomToolTip}">
                                                            <Grid>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <md:PackIcon Kind="Cancel" Width="15" Height="15" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding DisabledReason}" Foreground="#C62828" FontWeight="SemiBold" FontSize="13"/>
                                                                </StackPanel>
                                                                <StackPanel MinWidth="140" Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                                                Background="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                            <TextBlock Text="{Binding ShiftSetting.Alias}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding ShiftSetting.Name}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <ItemsControl ItemsSource="{Binding EntryItems}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                    <Border Width="28" Height="28" CornerRadius="14" ClipToBounds="True" Margin="0,0,8,0"
                                                                                            Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                                                        <Grid>
                                                                                            <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"
                                                                                                   Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                            <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                                       FontSize="10" FontWeight="Bold" Foreground="White"
                                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                    <TextBlock Text="{Binding Employee.Name}" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Text="（尚無排班）" FontSize="11" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                               Visibility="{Binding EntryItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <Grid Margin="12,8">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding ShiftSetting.Name}"
                                                                           FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                                        Background="#30FFFFFF">
                                                                    <TextBlock Text="{Binding ShiftSetting.Alias}" FontSize="11" Foreground="White"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock FontSize="12" Foreground="White" Opacity="0.85" Margin="0,0,0,8">
                                                                <Run Text="{Binding ShiftSetting.StartTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                <Run Text="–"/>
                                                                <Run Text="{Binding ShiftSetting.EndTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <ItemsControl ItemsSource="{Binding EntryItems}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                                                    PreviewMouseLeftButtonDown="EntryRow_PreviewMouseLeftButtonDown"
                                                                                    MouseMove="EntryRow_MouseMove"
                                                                                    MouseLeftButtonUp="EntryRow_MouseLeftButtonUp"
                                                                                    Cursor="Hand"
                                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    ContextMenu="{StaticResource EntryItemContextMenu}">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                            <Setter Property="Background" Value="#552196F3"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <Border Width="28" Height="28" CornerRadius="14" ClipToBounds="True" Margin="0,0,8,0"
                                                                                    Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                                    AllowDrop="True"
                                                                                    DragOver="EntryChip_DragOver"
                                                                                    Drop="EntryChip_Drop">
                                                                                <Grid>
                                                                                    <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"
                                                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                    <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                               FontSize="10" FontWeight="Bold" Foreground="White"
                                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                               Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <TextBlock Text="{Binding Employee.Name}" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Foreground="White" Width="28" Height="28" Padding="0"
                                                                ToolTip="推薦可排班員工"
                                                                Command="{Binding DataContext.OpenRecommendPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <md:PackIcon Kind="AccountSearch" Width="15" Height="15"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                    </Grid>

                    <!-- 衝突面板（右側抽屜式） -->
                    <Border Panel.ZIndex="20"
                            Visibility="{Binding IsConflictPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#55000000" CornerRadius="20"
                            MouseLeftButtonDown="ConflictPanelOverlay_Click">
                        <Border HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                Width="440" Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1,0,0,0"
                                CornerRadius="0,20,20,0" Padding="0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.2"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- 標題列 -->
                                <Grid DockPanel.Dock="Top" Margin="24,20,24,12">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <md:PackIcon Kind="AlertCircleOutline" Width="20" Height="20"
                                                     Foreground="#E53935" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock FontWeight="Bold" FontSize="{DynamicResource FontSizeSubTitle}" VerticalAlignment="Center"
                                                   Text="班表檢查"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32"
                                            Command="{Binding CloseConflictPanelCommand}">
                                        <md:PackIcon Kind="Close" Width="18" Height="18"/>
                                    </Button>
                                </Grid>

                                <!-- 內容區（衝突 + 空班別） -->
                                <ScrollViewer DockPanel.Dock="Top" Margin="0" Padding="24,0,24,0"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- 規則衝突區 -->
                                        <StackPanel Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <md:PackIcon Kind="AlertCircleOutline" Width="16" Height="16"
                                                             Foreground="#E53935" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock FontWeight="SemiBold" Foreground="#E53935" VerticalAlignment="Center">
                                                    <Run Text="規則衝突 ("/><Run Text="{Binding ConflictCount, Mode=OneWay}"/><Run Text=")"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding ConflictItems}" Margin="0,0,0,16">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:ScheduleConflict}">
                                                        <Border Margin="0,0,0,8" Padding="14,10"
                                                                Background="{DynamicResource AppPanelAltBrush}"
                                                                BorderBrush="#E5393540" BorderThickness="0,0,0,2"
                                                                CornerRadius="10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                        <TextBlock Text="{Binding EmployeeName}"
                                                                                   FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="{Binding ShiftAlias}"
                                                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Reason}"
                                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                                               Foreground="#E53935"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Date, StringFormat=MM/dd}"
                                                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                           FontSize="{DynamicResource FontSizeSmall}"
                                                                           VerticalAlignment="Top" Margin="12,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- 空班別區 -->
                                        <StackPanel Visibility="{Binding HasEmptyShifts, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <md:PackIcon Kind="CalendarAlert" Width="16" Height="16"
                                                             Foreground="#F57C00" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock FontWeight="SemiBold" Foreground="#F57C00" VerticalAlignment="Center">
                                                    <Run Text="空班別 ("/><Run Text="{Binding EmptyShiftTotalCount, Mode=OneWay}"/><Run Text=")"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding EmptyShiftItems}" Margin="0,0,0,16">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:EmptyShiftItem}">
                                                        <Border Margin="0,0,0,8" Padding="14,10"
                                                                Background="#FFF3E0"
                                                                BorderBrush="#F57C00" BorderThickness="0,0,0,2"
                                                                CornerRadius="10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border CornerRadius="4" Padding="6,2"
                                                                        Background="{Binding ShiftColor, Converter={StaticResource HexToBrushConverter}}">
                                                                    <TextBlock Text="{Binding ShiftAlias}"
                                                                               FontSize="11" Foreground="White" FontWeight="Bold"/>
                                                                </Border>
                                                                <TextBlock Grid.Column="1" Text="{Binding ShiftName}"
                                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                           FontSize="{DynamicResource FontSizeSmall}"
                                                                           VerticalAlignment="Center" Margin="12,0,0,0">
                                                                    <Run Text="{Binding Date, StringFormat=MM/dd}"/>
                                                                    <Run Text=" 週"/>
                                                                    <Run Text="{Binding DayOfWeekText, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- 空狀態 -->
                                        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasConflicts}" Value="False"/>
                                                                <Condition Binding="{Binding HasEmptyShifts}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <md:PackIcon Kind="CheckCircleOutline" Width="48" Height="48"
                                                         Foreground="#43A047" HorizontalAlignment="Center"/>
                                            <TextBlock Text="班表完整、無衝突"
                                                       Margin="0,10,0,0" HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- 再次檢查按鈕 -->
                                <Border DockPanel.Dock="Bottom" Padding="24,12"
                                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
                                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                            Command="{Binding CheckConflictsCommand}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="再次檢查" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Border>

                    <!-- 員工資訊卡浮層 -->
                    <Border Panel.ZIndex="25"
                            Visibility="{Binding IsEntryCardOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#66000000" CornerRadius="20"
                            MouseLeftButtonDown="EntryCardOverlay_Click">
                        <Border Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="20" Padding="24"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                MaxWidth="320"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- 關閉按鈕 -->
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32" Margin="0,-8,-8,0"
                                        Command="{Binding CloseEntryCardCommand}">
                                    <md:PackIcon Kind="Close" Width="16" Height="16"/>
                                </Button>
                                <!-- 大頭貼 + 姓名 -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <Border Width="56" Height="56" CornerRadius="28" ClipToBounds="True"
                                            HorizontalAlignment="Center" Margin="0,0,0,10"
                                            Background="{Binding EntryCardEmployee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                        <Grid>
                                            <Image Source="{Binding EntryCardEmployee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}" Stretch="UniformToFill"
                                                   Visibility="{Binding EntryCardEmployee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding EntryCardEmployee.DisplayInitial}"
                                                       FontSize="20" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding EntryCardEmployee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding EntryCardEmployee.Name}"
                                               FontSize="{DynamicResource FontSizeHeading}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding EntryCardShiftInfo}"
                                               Style="{StaticResource SubtleTextStyle}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <!-- 移除按鈕 -->
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                        Command="{Binding RemoveEntryFromCardCommand}"
                                        Height="36" Padding="16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="AccountRemove" Width="18" Height="18" Margin="0,0,6,0"/>
                                        <TextBlock Text="從班表移除"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- 新增班表表單（建立模式） -->
                    <StackPanel Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="16,12">

                        <!-- 標題 -->
                        <TextBlock Text="新增班表"
                                   FontSize="{DynamicResource FontSizeDialogTitle}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <!-- 月份選擇 -->
                        <TextBlock Text="產生月份" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,20">
                            <ComboBox ItemsSource="{Binding Source={x:Static vm:ScheduleViewModel.AvailableYears}}"
                                      SelectedItem="{Binding CreateYear}"
                                      Width="90" Margin="0,0,12,0"/>
                            <TextBlock Text="年" VerticalAlignment="Center" Margin="0,0,16,0"
                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                            <ComboBox ItemsSource="{Binding Source={x:Static vm:ScheduleViewModel.AvailableMonths}}"
                                      SelectedItem="{Binding CreateMonth}"
                                      Width="72" Margin="0,0,12,0"/>
                            <TextBlock Text="月" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                        </StackPanel>

                        <!-- 店休日 -->
                        <TextBlock Text="店休日" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Text="（從店鋪設定帶入，可在此調整本月店休週期）"
                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,6"/>
                        <ItemsControl ItemsSource="{Binding CreateClosedDayOptions}" Margin="0,0,0,20">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DayOfWeekOption}">
                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                              Margin="0,0,16,6"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 導入國定假日 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding ImportNationalHolidaysCommand}"
                                    IsEnabled="{Binding IsNotLoadingHolidays}"
                                    Height="36" Padding="12,0" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="CalendarImport" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="導入國定假日"/>
                                </StackPanel>
                            </Button>
                            <ProgressBar IsIndeterminate="True" Width="24" Height="24"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding IsLoadingHolidays, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ImportedHolidays}" Margin="0,0,0,16"
                                      Visibility="{Binding ImportedHolidays.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AppInfoBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="8,4" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding Label}" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource AppInfoForegroundBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 店休日變更警告 -->
                        <Border Background="#FFF3CD" CornerRadius="10" Padding="12,8" Margin="0,0,0,16"
                                Visibility="{Binding HasShiftDayWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AlertOutline" Width="18" Height="18" Margin="0,0,8,0"
                                             Foreground="#856404" VerticalAlignment="Center"/>
                                <TextBlock Text="店休日變更，已自動取消部分班別設定，請重新確認套用班別。"
                                           Foreground="#856404" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 套用班別 -->
                        <TextBlock Text="套用班別" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Text="（設定哪些班別在哪幾天顯示；不設定則全部顯示）"
                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,8"/>

                        <!-- 欄位標題列 -->
                        <Grid Margin="0,0,0,4"
                              Visibility="{Binding HasShiftAssignments, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="班別" Style="{StaticResource CaptionTextStyle}" Margin="4,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="一" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="二" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="三" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="四" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="五" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="六" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                <TextBlock Text="日" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 班別列表 -->
                        <ItemsControl ItemsSource="{Binding ShiftDayAssignments}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ShiftDayAssignmentItem}">
                                    <Border Background="{DynamicResource AppPanelAltBrush}"
                                            CornerRadius="10" Padding="8,6" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding AvailableShifts}"
                                                      SelectedItem="{Binding SelectedShift}"
                                                      DisplayMemberPath="Alias"
                                                      VerticalAlignment="Center"
                                                      Margin="4,0,8,0"/>

                                            <ItemsControl Grid.Column="1"
                                                          ItemsSource="{Binding DayCells}"
                                                          VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ShiftDayCell}">
                                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                                  IsEnabled="{Binding IsEnabled}"
                                                                  Width="36"
                                                                  HorizontalAlignment="Center"
                                                                  HorizontalContentAlignment="Center"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Grid.Column="2"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="32" Height="32"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.RemoveShiftAssignmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Close" Width="14" Height="14"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 新增班別按鈕 -->
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding AddShiftAssignmentCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,24"
                                Visibility="{Binding HasMoreShiftsToAdd, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="新增班別"/>
                            </StackPanel>
                        </Button>

                        <!-- 操作按鈕 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="取消"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding CancelCreateCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="確認建立"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding ConfirmCreateScheduleCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ═══ 自動排班表單 ═══ -->
                    <ScrollViewer Visibility="{Binding IsAutoAssigning, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,12">

                            <TextBlock Text="自動排班"
                                       FontSize="{DynamicResource FontSizeDialogTitle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,20"/>

                            <!-- 上班日設定條件 -->
                            <TextBlock Text="上班日設定條件" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="（各類上班日所需最低人力，空白則略過自動排班）"
                                       Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,8"/>

                            <Grid Margin="0,0,0,4"
                                  Visibility="{Binding HasWorkDayConditions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="最多每班人數" Style="{StaticResource CaptionTextStyle}" TextAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="最低每日人數" Style="{StaticResource CaptionTextStyle}" TextAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="一" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="二" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="三" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="四" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="五" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="六" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="日" Width="36" TextAlignment="Center" Style="{StaticResource CaptionTextStyle}"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding WorkDayConditions}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:WorkDayConditionItem}">
                                        <Border Background="{DynamicResource AppPanelAltBrush}"
                                                CornerRadius="10" Padding="8,6" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84"/>
                                                    <ColumnDefinition Width="84"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding MaxPerShift, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalAlignment="Center" HorizontalContentAlignment="Center" Margin="8,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding MinPerDay, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,8,0"/>
                                                <ItemsControl Grid.Column="2" ItemsSource="{Binding DayCells}" VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:WorkDayConditionCell}">
                                                            <CheckBox IsChecked="{Binding IsChecked}" IsEnabled="{Binding IsEnabled}"
                                                                      Width="36" HorizontalAlignment="Center" HorizontalContentAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Button Grid.Column="3" Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="32" Height="32" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveWorkDayConditionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <md:PackIcon Kind="Close" Width="14" Height="14"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AddWorkDayConditionCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="新增上班日條件"/>
                                </StackPanel>
                            </Button>

                            <!-- 員工個人設定 -->
                            <TextBlock Text="員工個人設定" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="（休假日、強制上班日儲存於本月班表；優先班別儲存於員工資料可跨月沿用）"
                                       Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,8" TextWrapping="Wrap"/>

                            <ItemsControl ItemsSource="{Binding EmployeeConstraints}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EmployeeConstraintItem}">
                                        <Border Background="{DynamicResource AppPanelAltBrush}"
                                                CornerRadius="10" Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <!-- 員工 + 類型切換 -->
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0"
                                                                  ItemsSource="{Binding DataContext.ActiveEmployees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding SelectedEmployee}"
                                                                  DisplayMemberPath="Name"
                                                                  Margin="0,0,8,0"/>
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding AvailableConstraintTypes}"
                                                                  SelectedItem="{Binding ConstraintType}"
                                                                  Width="110">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Converter={StaticResource ConstraintTypeToLabelConverter}}" FontSize="13"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>

                                                    <!-- 休假日：日期格選取（紅色） -->
                                                    <ItemsControl ItemsSource="{Binding DayOffCells}" Margin="0,0,0,4"
                                                                  Visibility="{Binding IsDayOff, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:DaySelectCell}">
                                                                <CheckBox IsChecked="{Binding IsChecked}" Margin="1,1,0,0">
                                                                    <CheckBox.Template>
                                                                        <ControlTemplate TargetType="CheckBox">
                                                                            <Border x:Name="Bd" Width="30" Height="28" CornerRadius="6"
                                                                                    BorderThickness="1"
                                                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                                                    Background="{DynamicResource AppPanelAltBrush}"
                                                                                    Cursor="Hand">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Bd" Property="Background" Value="#C62828"/>
                                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#B71C1C"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </CheckBox.Template>
                                                                    <TextBlock Text="{Binding Day}" FontSize="11">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </CheckBox>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- 上班日：日期格選取（綠色） -->
                                                    <ItemsControl ItemsSource="{Binding WorkDayCells}" Margin="0,0,0,4"
                                                                  Visibility="{Binding IsWorkDay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:DaySelectCell}">
                                                                <CheckBox IsChecked="{Binding IsChecked}" Margin="1,1,0,0">
                                                                    <CheckBox.Template>
                                                                        <ControlTemplate TargetType="CheckBox">
                                                                            <Border x:Name="Bd" Width="30" Height="28" CornerRadius="6"
                                                                                    BorderThickness="1"
                                                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                                                    Background="{DynamicResource AppPanelAltBrush}"
                                                                                    Cursor="Hand">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Bd" Property="Background" Value="#2E7D32"/>
                                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#1B5E20"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </CheckBox.Template>
                                                                    <TextBlock Text="{Binding Day}" FontSize="11">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </CheckBox>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- 優先班別 -->
                                                    <StackPanel Visibility="{Binding IsShiftPriority, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <ItemsControl ItemsSource="{Binding PriorityShifts}" Margin="0,0,0,6">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="8" Padding="6,3" Margin="0,0,4,4"
                                                                            Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Alias}" FontSize="12" Foreground="White"
                                                                                       VerticalAlignment="Center" Margin="0,0,2,0"/>
                                                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                                    Width="16" Height="16" Padding="0"
                                                                                    Command="{Binding DataContext.RemovePriorityShiftCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding}">
                                                                                <md:PackIcon Kind="Close" Width="10" Height="10" Foreground="White"/>
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal">
                                                            <ComboBox ItemsSource="{Binding DataContext.EnabledShifts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      SelectedItem="{Binding ShiftToAdd}"
                                                                      DisplayMemberPath="Alias"
                                                                      Width="100" Margin="0,0,8,0"/>
                                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                    Height="30" Padding="10,0" FontSize="12"
                                                                    Command="{Binding AddPriorityShiftCommand}">
                                                                <TextBlock Text="新增"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- 不排班：說明文字 -->
                                                    <TextBlock Text="此員工將被排除在自動排班之外"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               Visibility="{Binding IsExcludeAutoAssign, Converter={StaticResource BoolToVisibilityConverter}}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="32" Height="32" VerticalAlignment="Top"
                                                        Command="{Binding DataContext.RemoveEmployeeConstraintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <md:PackIcon Kind="Close" Width="14" Height="14"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AddEmployeeConstraintCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="新增員工設定"/>
                                </StackPanel>
                            </Button>

                            <!-- 進階選項 -->
                            <CheckBox IsChecked="{Binding OverwriteFromMonthStart}"
                                      Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="從月初開始（覆蓋已過日期）"/>
                                    <TextBlock Text="勾選後將清除本月所有排班並重新排定，包含今天以前的日期。"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </CheckBox>

                            <!-- 操作按鈕 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Content="取消"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding CancelAutoAssignCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="執行自動排班"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Command="{Binding ConfirmAutoAssignCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                    <!-- 拖拉阻擋提示 Popup -->
                    <Popup x:Name="DragTooltipPopup" AllowsTransparency="True" Placement="Mouse"
                           IsOpen="False" PopupAnimation="Fade">
                        <Border Background="#FFF9C4" BorderBrush="#4E342E" BorderThickness="2.5"
                                CornerRadius="10" Padding="12,8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.25"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Cancel" Width="15" Height="15" Foreground="#C62828"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="DragTooltipText" FontSize="13" FontWeight="SemiBold" Foreground="#C62828"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- ═══ 日期詳情 Overlay ═══ -->
                    <Border Panel.ZIndex="20"
                            Background="#88000000"
                            Visibility="{Binding IsDayDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                            MouseLeftButtonDown="DayDetailOverlay_Click">
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                MinWidth="360" MaxWidth="520"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1" CornerRadius="20" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="6" BlurRadius="24" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <!-- 標題列 -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DayDetailTitle}"
                                                   FontWeight="Bold"
                                                   FontSize="{DynamicResource FontSizeSubTitle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                    Visibility="{Binding DayDetailIsClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <md:PackIcon Kind="StoreOff" Width="13" Height="13" Margin="0,0,4,0"
                                                         Foreground="{DynamicResource AppSubtleForegroundBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="今日店休" Style="{StaticResource SubtleTextStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <!-- 非編輯模式的動作按鈕群 -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsShiftOverrideEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <!-- 設為店休（當天為上班日時顯示） -->
                                            <Button Visibility="{Binding DayDetailIsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                                    Command="{Binding SetDayDetailDayClosedCommand}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Foreground="#E53935" BorderBrush="#E53935"
                                                    Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="StoreOff" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="設為店休" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- 設為上班日（當天為店休時顯示） -->
                                            <Button Visibility="{Binding DayDetailIsClosed, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Command="{Binding SetDayDetailDayOpenCommand}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="Store" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="設為上班日" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- 調整班別（上班日時顯示） -->
                                            <Button Visibility="{Binding DayDetailIsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                                    Command="{Binding StartShiftOverrideEditCommand}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Height="32" Padding="10,0" Margin="0,0,8,0" FontSize="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="CalendarEdit" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="調整班別" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                Command="{Binding CloseDayDetailCommand}">
                                            <md:PackIcon Kind="Close" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- 店休訊息 -->
                                <Border DockPanel.Dock="Top" Padding="16,24"
                                        Visibility="{Binding ShowDayDetailClosedMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <md:PackIcon Kind="StoreOff" Width="40" Height="40" HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource AppSubtleForegroundBrush}" Opacity="0.5" Margin="0,0,0,10"/>
                                        <TextBlock Text="今日店休，無排班資料" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                   FontSize="{DynamicResource FontSizeSmall}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 班別分組 -->
                                <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding ShowDayDetailShiftGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding DayDetailGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ShiftBlock}">
                                                <Border Margin="0,0,0,12"
                                                        CornerRadius="12" Padding="14,10"
                                                        AllowDrop="True"
                                                        DragOver="ShiftBlock_DragOver"
                                                        Drop="ShiftBlock_Drop">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"      Value="{DynamicResource AppPanelAltBrush}"/>
                                                            <Setter Property="BorderBrush"     Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                    <Setter Property="Background"      Value="#FFF3E0"/>
                                                                    <Setter Property="BorderBrush"     Value="#F57C00"/>
                                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <!-- 班別標題 -->
                                                    <Grid>
                                                        <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <Border CornerRadius="6" Padding="8,3" Margin="0,0,10,0"
                                                                    Background="{Binding ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                <TextBlock Text="{Binding ShiftSetting.Alias}"
                                                                           FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding ShiftSetting.Name}"
                                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <TextBlock Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       FontSize="{DynamicResource FontSizeSmall}">
                                                                <Run Text="{Binding ShiftSetting.StartTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                                <Run Text="–"/>
                                                                <Run Text="{Binding ShiftSetting.EndTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- 員工晶片清單 -->
                                                        <ItemsControl ItemsSource="{Binding EntryItems}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:EntryItem}">
                                                                    <Border CornerRadius="16" Padding="8,4" Margin="0,0,8,6"
                                                                            BorderThickness="1"
                                                                            AllowDrop="True"
                                                                            DragOver="EntryChip_DragOver"
                                                                            Drop="EntryChip_Drop"
                                                                            PreviewMouseLeftButtonDown="EntryRow_PreviewMouseLeftButtonDown"
                                                                            MouseMove="EntryRow_MouseMove"
                                                                            MouseLeftButtonUp="EntryRow_MouseLeftButtonUp"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            ContextMenu="{StaticResource EntryItemContextMenu}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background"  Value="{DynamicResource AppSurfaceBrush}"/>
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                        <Setter Property="Background"  Value="#552196F3"/>
                                                                                        <Setter Property="BorderBrush" Value="#1976D2"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Border Width="26" Height="26" CornerRadius="13"
                                                                                    ClipToBounds="True" Margin="0,0,6,0"
                                                                                    Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                                                <Grid>
                                                                                    <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                                                           Stretch="UniformToFill"
                                                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                    <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                                               FontSize="10" FontWeight="Bold" Foreground="White"
                                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                               Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <TextBlock Text="{Binding Employee.Name}"
                                                                                       VerticalAlignment="Center"
                                                                                       FontSize="{DynamicResource FontSizeSmall}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <StackPanel Orientation="Horizontal"
                                                                    Visibility="{Binding EntryItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                                                            <md:PackIcon Kind="CalendarAlert" Width="14" Height="14"
                                                                         Foreground="#F57C00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="待排班"
                                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#F57C00"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        </StackPanel>
                                                        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                Style="{StaticResource MaterialDesignIconButton}"
                                                                Width="28" Height="28" Padding="0"
                                                                ToolTip="推薦可排班員工"
                                                                Command="{Binding DataContext.OpenRecommendPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <md:PackIcon Kind="AccountSearch" Width="15" Height="15"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- 班別覆寫編輯面板 -->
                                <Border DockPanel.Dock="Top" Padding="16"
                                        Visibility="{Binding IsShiftOverrideEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="選擇當日要顯示的班別：" Margin="0,0,0,10"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding ShiftOverrideCells}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ShiftOverrideCell}">
                                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border CornerRadius="6" Padding="8,3" Margin="0,0,8,0"
                                                                    Background="{Binding Shift.Color, Converter={StaticResource HexToBrushConverter}}">
                                                                <TextBlock Text="{Binding Shift.Alias}"
                                                                           FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Shift.Name}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="（未勾選任何班別表示當日無班別顯示）"
                                                   Margin="0,8,0,0"
                                                   FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                                    Command="{Binding SaveShiftOverrideCommand}"
                                                    Height="32" Padding="12,0" Margin="0,0,8,0" FontSize="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="Check" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="儲存" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding CancelShiftOverrideEditCommand}"
                                                    Height="32" Padding="12,0" Margin="0,0,8,0" FontSize="12">
                                                取消
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding ClearShiftOverrideCommand}"
                                                    Foreground="#E53935" BorderBrush="#E53935"
                                                    Visibility="{Binding DayDetailDayHasOverride, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Height="32" Padding="12,0" FontSize="12">
                                                清除自訂
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- 推薦員工浮層 -->
            <Border Grid.ColumnSpan="3" Panel.ZIndex="30"
                    Visibility="{Binding IsRecommendPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#88000000"
                    MouseLeftButtonDown="RecommendOverlay_Click">
                <Border Background="{DynamicResource AppSurfaceBrush}"
                        CornerRadius="16" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        MinWidth="520" MaxWidth="680" MaxHeight="520"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.25"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 標題列 -->
                        <Border Grid.Row="0" Padding="20,14"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Padding="8,3" Margin="0,0,10,0"
                                            Background="{Binding RecommendTargetShift.ShiftSetting.Color, Converter={StaticResource HexToBrushConverter}}">
                                        <TextBlock Text="{Binding RecommendTargetShift.ShiftSetting.Alias}"
                                                   FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="推薦可排班員工"
                                               FontWeight="SemiBold" FontSize="{DynamicResource FontSizeSubTitle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32" VerticalAlignment="Top"
                                        Command="{Binding CloseRecommendPanelCommand}">
                                    <md:PackIcon Kind="Close" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </Border>
                        <!-- 候選人列表 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="目前無符合條件的員工"
                                           Style="{StaticResource SubtleTextStyle}"
                                           HorizontalAlignment="Center" Margin="0,24"
                                           Visibility="{Binding RecommendCandidates.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding RecommendCandidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:RecommendEmployeeItem}">
                                            <Border Padding="20,12"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 員工頭像 + 姓名 -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                                VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <Border Width="32" Height="32" CornerRadius="16"
                                                                ClipToBounds="True" Margin="0,0,8,0"
                                                                Background="{Binding Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                            <Grid>
                                                                <Image Source="{Binding Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                                       Stretch="UniformToFill"
                                                                       Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding Employee.DisplayInitial}"
                                                                           FontSize="12" FontWeight="Bold" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding Employee.Name}"
                                                                   VerticalAlignment="Center" FontWeight="Medium"/>
                                                    </StackPanel>
                                                    <!-- 班別統計 -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel.Resources>
                                                            <DataTemplate x:Key="RecommendShiftChip" DataType="{x:Type vm:EmployeeDetailShiftStat}">
                                                                <Border Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                        CornerRadius="4" Padding="5,2" Margin="0,0,4,0">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding ShiftAlias}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                                                                        <TextBlock Text="{Binding Count, StringFormat=' ×{0}'}" FontSize="12" Foreground="White" Opacity="0.8"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </StackPanel.Resources>
                                                        <ItemsControl ItemsSource="{Binding ShiftStatsRow1}"
                                                                      ItemTemplate="{StaticResource RecommendShiftChip}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                        <ItemsControl ItemsSource="{Binding ShiftStatsRow2}"
                                                                      ItemTemplate="{StaticResource RecommendShiftChip}"
                                                                      Margin="0,4,0,0"
                                                                      Visibility="{Binding ShiftStatsRow2.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <!-- 加入按鈕 -->
                                                    <Button Grid.Column="2" VerticalAlignment="Center"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="36" Height="36"
                                                            Command="{Binding DataContext.AssignRecommendedEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <md:PackIcon Kind="Plus" Width="18" Height="18"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>

            <!-- 員工本月排班詳情浮層 -->
            <Border Grid.ColumnSpan="3" Panel.ZIndex="40"
                    Visibility="{Binding IsEmployeeDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#66000000"
                    MouseLeftButtonDown="EmployeeDetailOverlay_Click">
                <Border Background="{DynamicResource AppSurfaceBrush}"
                        CornerRadius="20" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        MinWidth="600" MaxHeight="560"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.25"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 標題列 -->
                        <Border Grid.Row="0" Padding="20,16"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="22" ClipToBounds="True" Margin="0,0,12,0"
                                            Background="{Binding EmployeeDetailItem.Employee.ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                        <Grid>
                                            <Image Source="{Binding EmployeeDetailItem.Employee.AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding EmployeeDetailItem.Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding EmployeeDetailItem.Employee.DisplayInitial}"
                                                       FontSize="17" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding EmployeeDetailItem.Employee.AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EmployeeDetailItem.Employee.Name}"
                                                   FontWeight="SemiBold" FontSize="{DynamicResource FontSizeSubTitle}"/>
                                        <TextBlock FontSize="12" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}">
                                            <Run Text="本月已排 "/>
                                            <Run Text="{Binding EmployeeDetailItem.ShiftCount, Mode=OneWay}"/>
                                            <Run Text=" / 可排 "/>
                                            <Run Text="{Binding EmployeeDetailItem.TargetCount, Mode=OneWay}"/>
                                            <Run Text=" 班"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- 班別統計 -->
                                    <Border Width="1" Margin="12,4" Background="{DynamicResource AppBorderBrush}"
                                            Visibility="{Binding EmployeeDetailShiftStatsRow1.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    <StackPanel VerticalAlignment="Center"
                                                Visibility="{Binding EmployeeDetailShiftStatsRow1.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <StackPanel.Resources>
                                            <DataTemplate x:Key="ShiftStatChip" DataType="{x:Type vm:EmployeeDetailShiftStat}">
                                                <Border Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                        CornerRadius="4" Padding="6,3" Margin="0,0,4,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ShiftAlias}" FontSize="13" Foreground="White" FontWeight="Medium"/>
                                                        <TextBlock Text="{Binding Count, StringFormat=' ×{0}'}" FontSize="13" Foreground="White" Opacity="0.8"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </StackPanel.Resources>
                                        <ItemsControl ItemsSource="{Binding EmployeeDetailShiftStatsRow1}"
                                                      ItemTemplate="{StaticResource ShiftStatChip}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding EmployeeDetailShiftStatsRow2}"
                                                      ItemTemplate="{StaticResource ShiftStatChip}"
                                                      Margin="0,4,0,0"
                                                      Visibility="{Binding EmployeeDetailShiftStatsRow2.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" VerticalAlignment="Top"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32"
                                        Command="{Binding CloseEmployeeDetailCommand}">
                                    <md:PackIcon Kind="Close" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 主體：左欄（限制 + 預留）＋ 右欄（排班明細） -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ── 左欄 ── -->
                            <Border Grid.Column="0"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 排班限制 -->
                                <StackPanel Grid.Row="0" Margin="16,12,12,12">
                                    <TextBlock Text="排班限制"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                               Margin="0,0,0,8"/>
                                    <!-- 無規則 -->
                                    <TextBlock Text="無"
                                               FontSize="12"
                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                               Visibility="{Binding EmployeeDetailRules.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                    <!-- 規則列表 -->
                                    <ItemsControl ItemsSource="{Binding EmployeeDetailRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:EmployeeRuleDisplayItem}">
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Detail}"
                                                               FontSize="12" FontWeight="Medium"
                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- 分隔線 -->
                                <Border Grid.Row="1" Height="1"
                                        Background="{DynamicResource AppBorderBrush}"
                                        Margin="16,0,12,0"/>

                                <!-- 優先班別 + 本月休息日 -->
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="16,12,12,12">
                                        <!-- 優先班別（唯讀） -->
                                        <TextBlock Text="優先班別"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="未設定"
                                                   FontSize="12" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                   Margin="0,0,0,8"
                                                   Visibility="{Binding EmployeeDetailPriorityShifts.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                        <ItemsControl ItemsSource="{Binding EmployeeDetailPriorityShifts}"
                                                      Margin="0,0,0,8"
                                                      Visibility="{Binding EmployeeDetailPriorityShifts.Count, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="12" Margin="0,0,0,3"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 本月休息日（可編輯） -->
                                        <TextBlock Text="本月休息日"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                   Margin="0,8,0,6"/>
                                        <ItemsControl ItemsSource="{Binding EmployeeDetailDayOffs}" Margin="0,0,0,6">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="6,3" Margin="0,0,4,4"
                                                            Background="{DynamicResource AppInfoBrush}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource AppInfoForegroundBrush}" Margin="0,0,2,0"/>
                                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                                    Width="16" Height="16" Padding="0"
                                                                    Command="{Binding DataContext.RemoveEmployeeDetailDayOffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <md:PackIcon Kind="Close" Width="9" Height="9"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- 新增休息日 -->
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox ItemsSource="{Binding AvailableEmployeeDetailDays}"
                                                      SelectedItem="{Binding EmployeeDetailNewDayOff}"
                                                      Width="66" Margin="0,0,6,0"/>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="28" Height="28"
                                                    Command="{Binding AddEmployeeDetailDayOffCommand}">
                                                <md:PackIcon Kind="Plus" Width="14" Height="14"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- ── 右欄：排班明細 ── -->
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,4">
                                <StackPanel>
                                    <TextBlock Text="本月尚無排班記錄"
                                               Style="{StaticResource SubtleTextStyle}"
                                               HorizontalAlignment="Center" Margin="0,24"
                                               Visibility="{Binding EmployeeDetailEntries.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding EmployeeDetailEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:EmployeeDetailEntry}">
                                                <Border Padding="16,10"
                                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DateText}" FontWeight="Medium" FontSize="13"/>
                                                            <TextBlock Text="{Binding DayOfWeekText}" FontSize="11"
                                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                CornerRadius="4" Padding="6,3">
                                                            <TextBlock Text="{Binding ShiftAlias}"
                                                                       Foreground="White" FontWeight="Medium"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding TimeRange}"
                                                                   VerticalAlignment="Center" FontSize="11"
                                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                                        <!-- 同天排班同仁頭像 -->
                                                        <ItemsControl Grid.Column="3" ItemsSource="{Binding Colleagues}"
                                                                      VerticalAlignment="Center">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type models:Employee}">
                                                                    <Border Width="32" Height="32" CornerRadius="16"
                                                                            ClipToBounds="True" Margin="4,0,0,0"
                                                                            BorderThickness="2" BorderBrush="{DynamicResource AppSurfaceBrush}"
                                                                            Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                                                            ToolTipOpening="AvatarChip_ToolTipOpening">
                                                                        <Border.ToolTip>
                                                                            <ToolTip Style="{StaticResource SpeechBubbleToolTip}">
                                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                                    <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True" Margin="0,0,6,0"
                                                                                            Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}">
                                                                                        <Grid>
                                                                                            <Image Source="{Binding AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                                                                   Stretch="UniformToFill"
                                                                                                   Visibility="{Binding AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                                            <TextBlock Text="{Binding DisplayInitial}"
                                                                                                       FontSize="9" FontWeight="Bold" Foreground="White"
                                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Visibility="{Binding AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                                                                </StackPanel>
                                                                            </ToolTip>
                                                                        </Border.ToolTip>
                                                                        <Grid>
                                                                            <Image Source="{Binding AvatarPhotoData, Converter={StaticResource BytesToImageConverter}}"
                                                                                   Stretch="UniformToFill"
                                                                                   Visibility="{Binding AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                            <TextBlock Text="{Binding DisplayInitial}"
                                                                                       FontSize="11" FontWeight="Bold" Foreground="White"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                       Visibility="{Binding AvatarPhotoData, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
