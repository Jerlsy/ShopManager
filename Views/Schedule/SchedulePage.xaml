<UserControl x:Class="ShopManager.Views.Schedule.SchedulePage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:vm="clr-namespace:ShopManager.ViewModels">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════ -->
        <!-- 左側：員工清單面板                    -->
        <!-- ══════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Padding="12">
            <DockPanel>
                <ui:TextBlock Text="在職員工" FontTypography="BodyStrong"
                              DockPanel.Dock="Top" Margin="0,0,0,8"/>

                <TextBlock Text="（點選員工以檢視限制，拖放到班別格子排班）"
                           FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           DockPanel.Dock="Top" Margin="0,0,0,8"/>

                <ListBox ItemsSource="{Binding ActiveEmployees}"
                         SelectedItem="{Binding SelectedEmployee}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="AllowDrop" Value="False"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       MouseLeftButtonDown="Employee_MouseLeftButtonDown"
                                       Cursor="Hand"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════ -->
        <!-- 右側：行事曆主區域                    -->
        <!-- ══════════════════════════════════ -->
        <DockPanel Grid.Column="1" Margin="16,12,12,12">

            <!-- ── 頂部工具列 ─────────────── -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 月份導覽 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronLeft24}"
                               Command="{Binding PreviousMonthCommand}"
                               Appearance="Secondary" Margin="0,0,4,0"/>
                    <ui:TextBlock Text="{Binding CalendarTitle}" FontTypography="Subtitle"
                                  VerticalAlignment="Center" Margin="8,0,8,0"/>
                    <ui:Button Icon="{ui:SymbolIcon Symbol=ChevronRight24}"
                               Command="{Binding NextMonthCommand}"
                               Appearance="Secondary" Margin="4,0,8,0"/>
                    <ui:Button Content="今天" Command="{Binding GoToTodayCommand}"
                               Appearance="Secondary" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 視圖切換 + 新增班表 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding ViewModeOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding ViewMode}"
                              Width="80" Margin="0,0,8,0"/>
                    <ui:Button Content="新增班表"
                               Icon="{ui:SymbolIcon Symbol=CalendarAdd24}"
                               Appearance="Primary"
                               Command="{Binding StartCreateScheduleCommand}"
                               Visibility="{Binding HasSchedule,
                                   Converter={StaticResource BoolToVisibilityConverter},
                                   ConverterParameter=Inverse}"/>
                </StackPanel>
            </Grid>

            <!-- ── 建立班表對話框 ────────────── -->
            <Border DockPanel.Dock="Top"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                    <ui:TextBlock Text="新增班表" FontTypography="Subtitle" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,16,0">
                            <ui:TextBlock Text="年" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AvailableYears}"
                                      SelectedItem="{Binding CreateYear}"
                                      Width="100"/>
                        </StackPanel>
                        <StackPanel>
                            <ui:TextBlock Text="月" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AvailableMonths}"
                                      SelectedItem="{Binding CreateMonth}"
                                      Width="80"/>
                        </StackPanel>
                    </StackPanel>

                    <ui:TextBlock Text="該月店休日（可調整）" FontTypography="BodyStrong" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding CreateClosedDayOptions}" Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Label}"
                                          IsChecked="{Binding IsChecked}"
                                          Margin="0,0,16,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="建立" Appearance="Primary" Margin="0,0,8,0"
                                   Command="{Binding ConfirmCreateScheduleCommand}"/>
                        <ui:Button Content="取消" Command="{Binding CancelCreateCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── 尚無班表提示 ────────────── -->
            <StackPanel Visibility="{Binding HasSchedule,
                            Converter={StaticResource BoolToVisibilityConverter},
                            ConverterParameter=Inverse}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="CalendarEmpty24" FontSize="64"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                <ui:TextBlock Text="此月份尚未建立班表" FontTypography="Body"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <ui:TextBlock Text="請點擊「新增班表」開始建立" FontTypography="Caption"
                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ════════════════════════════════ -->
            <!-- 月視圖                            -->
            <!-- ════════════════════════════════ -->
            <ScrollViewer Visibility="{Binding HasSchedule,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <!-- 月視圖 -->
                    <StackPanel x:Name="MonthViewPanel"
                                Visibility="{Binding ViewMode,
                                    Converter={StaticResource ViewModeVisibilityConverter},
                                    ConverterParameter=Month}">

                        <!-- 星期標題列 -->
                        <ItemsControl x:Name="WeekHeaders">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- 日曆格子 -->
                        <ItemsControl ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MinHeight="100" Margin="1" CornerRadius="4"
                                            AllowDrop="True"
                                            Drop="ShiftBlock_Drop"
                                            DragOver="ShiftBlock_DragOver"
                                            MouseLeftButtonDown="CalendarDay_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                        <Setter Property="Background" Value="#30808080"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                                        <Setter Property="Background" Value="#15808080"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel Margin="4" Visibility="{Binding IsPlaceholder,
                                                        Converter={StaticResource BoolToVisibilityConverter},
                                                        ConverterParameter=Inverse}">
                                            <!-- 日期數字 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock FontSize="12" Margin="0,0,4,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Day}"/>
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                            <Setter Property="Foreground"
                                                                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                                    <Setter Property="Foreground" Value="Gray"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding DayOfWeekText}" FontSize="10"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="休" FontSize="10" Foreground="Gray"
                                                           Margin="4,0,0,0" VerticalAlignment="Center"
                                                           Visibility="{Binding IsClosed,
                                                               Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- 班別色塊 -->
                                            <ItemsControl ItemsSource="{Binding ShiftBlocks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="3" Padding="4,2" Margin="0,1"
                                                                AllowDrop="True"
                                                                Drop="ShiftBlock_Drop"
                                                                DragOver="ShiftBlock_DragOver"
                                                                Tag="{Binding}"
                                                                Background="{Binding ShiftSetting.Color,
                                                                    Converter={StaticResource HexToBrushConverter}}"
                                                                Opacity="{Binding IsDisabled,
                                                                    Converter={StaticResource BoolToOpacityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ShiftSetting.Alias}"
                                                                           FontSize="10" Foreground="White"
                                                                           FontWeight="SemiBold"/>
                                                                <!-- 已排員工 -->
                                                                <ItemsControl ItemsSource="{Binding Employees}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontSize="9" Foreground="#DDFFFFFF"
                                                                                       Margin="0,1,0,0"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 周/日視圖 — 時間軸 -->
                    <StackPanel x:Name="TimeViewPanel"
                                Visibility="{Binding ViewMode,
                                    Converter={StaticResource ViewModeVisibilityConverter},
                                    ConverterParameter=WeekOrDay}">

                        <!-- 周視圖的日期標題列 -->
                        <ItemsControl ItemsSource="{Binding CalendarDays}"
                                      Margin="50,0,0,0"
                                      Visibility="{Binding ViewMode,
                                          Converter={StaticResource ViewModeVisibilityConverter},
                                          ConverterParameter=Week}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,8"
                                               Cursor="Hand"
                                               MouseLeftButtonDown="WeekDayHeader_Click">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding DayOfWeekText, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Day, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 時間軸列 -->
                        <ItemsControl ItemsSource="{Binding TimeSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 時間標籤 -->
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="11" VerticalAlignment="Top"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,0,8,0"/>
                                        <!-- 每天的格子 -->
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="1" CornerRadius="2"
                                                            AllowDrop="True"
                                                            Drop="ShiftBlock_Drop"
                                                            DragOver="ShiftBlock_DragOver"
                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,0.5">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsClosed}" Value="True">
                                                                        <Setter Property="Background" Value="#20808080"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <ItemsControl ItemsSource="{Binding ShiftBlocks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="3" Padding="4,2" Margin="1"
                                                                            AllowDrop="True"
                                                                            Drop="ShiftBlock_Drop"
                                                                            DragOver="ShiftBlock_DragOver"
                                                                            Tag="{Binding}"
                                                                            Background="{Binding ShiftSetting.Color,
                                                                                Converter={StaticResource HexToBrushConverter}}"
                                                                            Opacity="{Binding IsDisabled,
                                                                                Converter={StaticResource BoolToOpacityConverter}}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding ShiftSetting.Alias}"
                                                                                       FontSize="10" Foreground="White"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="0,0,4,0"/>
                                                                            <ItemsControl ItemsSource="{Binding Employees}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <StackPanel Orientation="Horizontal"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                   FontSize="9"
                                                                                                   Foreground="#DDFFFFFF"
                                                                                                   Margin="2,0,0,0"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
