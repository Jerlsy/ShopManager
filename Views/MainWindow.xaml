<ui:FluentWindow x:Class="ShopManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shopSettings="clr-namespace:ShopManager.Views.ShopSettings"
        xmlns:shiftSettings="clr-namespace:ShopManager.Views.ShiftSettings"
        xmlns:salarySettings="clr-namespace:ShopManager.Views.SalarySettings"
        xmlns:employeeMgmt="clr-namespace:ShopManager.Views.EmployeeManagement"
        xmlns:schedule="clr-namespace:ShopManager.Views.Schedule"
        Title="店鋪管理系統"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自訂標題列 -->
        <ui:TitleBar Grid.Row="0"
                     Title="店鋪管理系統">
            <ui:TitleBar.TrailingContent>
                <TextBlock Text="{Binding ShopName}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,12,0"/>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- 側邊導覽 + 作業視窗 -->
        <ui:NavigationView Grid.Row="1"
                           x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="200"
                           Loaded="RootNavigation_Loaded">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="店舖設定"
                                       Icon="{ui:SymbolIcon Symbol=Settings24}"
                                       TargetPageType="{x:Type shopSettings:ShopSettingPage}"/>

                <ui:NavigationViewItem Content="班別設定"
                                       Icon="{ui:SymbolIcon Symbol=Clock24}"
                                       TargetPageType="{x:Type shiftSettings:ShiftSettingPage}"
                                       Visibility="{Binding IsSystemConfigured,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ui:NavigationViewItem Content="薪資設定"
                                       Icon="{ui:SymbolIcon Symbol=Money24}"
                                       TargetPageType="{x:Type salarySettings:SalarySettingPage}"
                                       Visibility="{Binding IsSystemConfigured,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ui:NavigationViewItem Content="員工資料管理"
                                       Icon="{ui:SymbolIcon Symbol=People24}"
                                       TargetPageType="{x:Type employeeMgmt:EmployeeListPage}"
                                       Visibility="{Binding IsSystemConfigured,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ui:NavigationViewItem Content="排班管理"
                                       Icon="{ui:SymbolIcon Symbol=CalendarLtr24}"
                                       TargetPageType="{x:Type schedule:SchedulePage}"
                                       Visibility="{Binding IsSystemConfigured,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="關於系統"
                                       Icon="{ui:SymbolIcon Symbol=Info24}"/>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>

        <!-- Snackbar 通知 -->
        <ui:SnackbarPresenter x:Name="RootSnackbar"
                              Grid.Row="1"/>

        <!-- ContentDialog 對話框宿主 -->
        <ui:ContentDialogHost x:Name="RootContentDialog"
                              Grid.Row="0" Grid.RowSpan="2"/>
    </Grid>
</ui:FluentWindow>
