<Window x:Class="ShopManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ShopManager.ViewModels"
        Title="ShopManager"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="{DynamicResource AppShellBackgroundBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontFamily="{md:MaterialDesignFont}"
        FontSize="14">

    <md:DialogHost Identifier="RootDialog" CloseOnClickAway="False">
        <Grid x:Name="WindowRoot">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{DynamicResource AppShellGradientStartColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource AppShellGradientMidColor}" Offset="0.55"/>
                    <GradientStop Color="{DynamicResource AppShellGradientEndColor}" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="{Binding ElementName=WindowRoot, Path=ActualWidth, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.7}"
                    MinHeight="{Binding ElementName=WindowRoot, Path=ActualHeight, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.7}"
                    MaxWidth="{Binding ElementName=WindowRoot, Path=ActualWidth, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.95}"
                    MaxHeight="{Binding ElementName=WindowRoot, Path=ActualHeight, Converter={StaticResource MultiplyDoubleConverter}, ConverterParameter=0.95}"
                    CornerRadius="36"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="36,36,0,0"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="16"
                                        Background="#E3EBF3">
                                    <md:PackIcon Kind="StorefrontOutline"
                                                 Width="22"
                                                 Height="22"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="ShopManager"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ShopName}"
                                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <Button Width="40"
                                        Height="40"
                                        Margin="0,0,8,0"
                                        Click="MinimizeWindow_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="最小化">
                                    <md:PackIcon Kind="Minus" Width="18" Height="18"/>
                                </Button>
                                <Button Width="40"
                                        Height="40"
                                        Click="CloseWindow_Click"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="關閉">
                                    <md:PackIcon Kind="Close" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="20"
                                    CornerRadius="28"
                                    Background="{DynamicResource AppPanelBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Top">
                                        <TextBlock Text="導航"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   Opacity="0.88"/>
                                        <TextBlock Text="主導航欄已固定。內容超出時各頁面將獨立捲動。"
                                                   Margin="0,6,0,18"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                    </StackPanel>

                                    <Border DockPanel.Dock="Bottom"
                                            Margin="0,20,0,0"
                                            CornerRadius="24"
                                            Background="{DynamicResource AppSurfaceBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="配色設定"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="已移至店舖設定頁內集中管理。"
                                                       Margin="0,6,0,0"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <ListBox ItemsSource="{Binding VisibleNavItems}"
                                             SelectedItem="{Binding SelectedNavItem}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="16,12"/>
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder"
                                                                    Background="Transparent"
                                                                    CornerRadius="22"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder"
                                                                            Property="Background"
                                                                            Value="{DynamicResource AppSelectionBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder"
                                                                            Property="Background"
                                                                            Value="{DynamicResource AppHoverBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:NavItem}">
                                                <DockPanel LastChildFill="True">
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="17"
                                                            Background="{DynamicResource AppSurfaceBrush}"
                                                            Margin="0,0,14,0">
                                                        <md:PackIcon Kind="{Binding Icon}"
                                                                     Width="18"
                                                                     Height="18"
                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Label}"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="Medium"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="24,18"
                                        CornerRadius="28"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedNavItem.Label, FallbackValue=店舖設定}"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="內容面板現在支援獨立捲動與正確的滾輪反應。"
                                                   Margin="0,6,0,0"
                                                   Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Border Background="{DynamicResource AppSurfaceBrush}"
                                            CornerRadius="32"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"/>

                                    <Grid Margin="10">
                                        <ContentControl Content="{Binding CurrentContent}"
                                                        Focusable="False"/>
                                        <md:Snackbar x:Name="RootSnackbar"
                                                     VerticalAlignment="Bottom"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,0,0,16"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </md:DialogHost>
</Window>


