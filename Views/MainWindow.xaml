<Window x:Class="ShopManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ShopManager.ViewModels"
        Title="ShopManager"
        Icon="/Resources/app.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <md:DialogHost x:Name="RootDialogHost" Identifier="RootDialog"
                   DialogTheme="Inherit">
        <Grid x:Name="WindowRoot">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{DynamicResource AppShellGradientStartColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource AppShellGradientMidColor}" Offset="0.55"/>
                    <GradientStop Color="{DynamicResource AppShellGradientEndColor}" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border Background="Transparent"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 頂部自定義標題列 -->
                    <Grid Grid.Row="0" Background="Transparent" Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                            <Image Source="/Resources/logo.png" Width="22" Height="22" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="ShopManager" Margin="10,0,0,0" FontWeight="Bold" Opacity="0.7"/>
                            <TextBlock Text=" · " Margin="4,0" Opacity="0.3"/>
                            <TextBlock Text="{Binding ShopContext.CurrentShop.Name}" Opacity="0.5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Click="MinimizeWindow_Click">
                                <md:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="36" Height="36" Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}" Click="CloseWindow_Click">
                                <md:PackIcon Kind="Close" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 主內容區 -->
                    <Grid Grid.Row="1" Margin="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- 導航欄：依螢幕寬度縮放（NavColumnWidth） -->
                                <ColumnDefinition Width="{Binding NavColumnWidth}"/>
                                <!-- 間距 -->
                                <ColumnDefinition Width="8"/>
                                <!-- 內容區 -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左側導航（展開狀態）-->
                            <Border Grid.Column="0"
                                    Padding="12"
                                    CornerRadius="16"
                                    Background="{DynamicResource AppPanelBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding IsNavExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DockPanel LastChildFill="True">
                                    <!-- 頂部：標題 + 收折按鈕 -->
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="導航菜單"
                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                       Opacity="0.88"/>
                                            <TextBlock Text="切換功能頁面以管理店鋪資訊、員工及排班。"
                                                       Margin="0,4,0,0"
                                                       FontSize="{DynamicResource FontSizeSmallBody}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                VerticalAlignment="Top"
                                                Command="{Binding ToggleNavCommand}"
                                                ToolTip="收起導航">
                                            <md:PackIcon Kind="MenuOpen" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>

                                    <md:PopupBox DockPanel.Dock="Bottom"
                                                 Margin="0,8,0,0"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                 PopupMode="Click"
                                                 PlacementMode="TopAndAlignLeftEdges">
                                        <md:PopupBox.ToggleContent>
                                            <StackPanel Orientation="Horizontal">
                                                <md:PackIcon Kind="LogoutVariant" Width="18" Height="18" Margin="0,0,8,0"/>
                                                <TextBlock Text="離開店鋪"/>
                                            </StackPanel>
                                        </md:PopupBox.ToggleContent>
                                        <StackPanel Width="160">
                                            <Button Content="切換店鋪" Command="{Binding LeaveShopCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                                            <Button Content="退出程式" Command="{Binding ExitAppCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"/>
                                        </StackPanel>
                                    </md:PopupBox>

                                    <ListBox ItemsSource="{Binding VisibleNavItems}"
                                             SelectedItem="{Binding SelectedNavItem}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="Margin" Value="0,0,0,4"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder"
                                                                    Background="Transparent"
                                                                    CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppHoverBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:NavItem}">
                                                <DockPanel LastChildFill="True">
                                                    <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AppSurfaceBrush}" Margin="0,0,10,0">
                                                        <md:PackIcon Kind="{Binding Icon}" Width="15" Height="15" Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeSmallBody}" FontWeight="Medium"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <!-- 左側導航（收折狀態）-->
                            <Border Grid.Column="0"
                                    CornerRadius="16"
                                    Background="{DynamicResource AppPanelBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    Visibility="{Binding IsNavExpanded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                <DockPanel LastChildFill="False">
                                    <!-- 展開按鈕靠上 -->
                                    <Button DockPanel.Dock="Top"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Width="44" Height="44"
                                            ToolTip="展開導航"
                                            Command="{Binding ToggleNavCommand}">
                                        <md:PackIcon Kind="Menu" Width="18" Height="18"/>
                                    </Button>
                                    <!-- 功能圖示靠上 -->
                                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding VisibleNavItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:NavItem}">
                                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="44" Height="44"
                                                        ToolTip="{Binding Label}"
                                                        Command="{Binding DataContext.SelectNavItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <md:PackIcon Kind="{Binding Icon}" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- 離開店鋪按鈕靠下 -->
                                    <md:PopupBox DockPanel.Dock="Bottom" Margin="0,0,0,4"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                 PopupMode="Click"
                                                 PlacementMode="RightAndAlignTopEdges">
                                        <md:PopupBox.ToggleContent>
                                            <md:PackIcon Kind="LogoutVariant" Width="18" Height="18"/>
                                        </md:PopupBox.ToggleContent>
                                        <StackPanel Width="140">
                                            <Button Content="切換店鋪" Command="{Binding LeaveShopCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                                            <Button Content="退出程式" Command="{Binding ExitAppCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"/>
                                        </StackPanel>
                                    </md:PopupBox>
                                </DockPanel>
                            </Border>

                            <!-- 右側內容區塊 -->
                            <Grid Grid.Column="2" x:Name="ContentArea">
                                <!-- 實作：長寬各佔主容器 70% 最小限制，且在超過 95% 時才顯示捲軸 -->
                                <ScrollViewer x:Name="PageScrollViewer"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Grid.MinWidth>
                                            <MultiBinding Converter="{StaticResource MultiplyDoubleConverter}">
                                                <Binding ElementName="ContentArea" Path="ActualWidth"/>
                                                <Binding Source="0.9"/>
                                            </MultiBinding>
                                        </Grid.MinWidth>
                                        <Grid.MinHeight>
                                            <MultiBinding Converter="{StaticResource MultiplyDoubleConverter}">
                                                <Binding ElementName="ContentArea" Path="ActualHeight"/>
                                                <Binding Source="0.7"/>
                                            </MultiBinding>
                                        </Grid.MinHeight>
                                        
                                        <!-- HorizontalAlignment="Left" 確保左邊距與導航欄維持固定 8px gap，不會因捲軸顯示與否而偏移 -->
                                        <Border HorizontalAlignment="Left"
                                                Width="{Binding ElementName=PageScrollViewer, Path=ViewportWidth}">
                                            <ContentControl Content="{Binding CurrentContent}" Focusable="False"/>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>
                                
                                <md:Snackbar x:Name="RootSnackbar" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </md:DialogHost>
</Window>