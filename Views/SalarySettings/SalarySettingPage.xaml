<UserControl x:Class="ShopManager.Views.SalarySettings.SalarySettingPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:models="clr-namespace:ShopManager.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頁首標題列 + 操作按鈕欄 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="薪資設定"
                       FontSize="30" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                       
                        Margin="0,0,8,0"
                        Command="{Binding OpenLaborLawCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="FileAccount" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="勞基法設定" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                       
                        Command="{Binding StartNewCommand}"
                        Visibility="{Binding ShowLaborLaw,
                            Converter={StaticResource BoolToVisibilityConverter},
                            ConverterParameter=Inverse}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="新增薪資" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        
        <!-- 主要欄:薪資清單 + 編輯表單                   -->
        
        <Grid Grid.Row="1"
              Visibility="{Binding ShowLaborLaw,
                  Converter={StaticResource BoolToVisibilityConverter},
                  ConverterParameter=Inverse}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 薪資列表 -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Salaries}"
                     SelectedItem="{Binding SelectedSalary}"
                     Style="{StaticResource MaterialDesignListBox}"
                     Margin="0,0,16,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Alias}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Type, Converter={StaticResource SalaryTypeDisplayConverter}}"
                                           FontSize="12" Opacity="0.65"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11" Opacity="0.45"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.StartEditCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.DeleteCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 薪資編輯欄 -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding IsEditing,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedSalary,
                                       Converter={StaticResource NullToStringConverter},
                                       ConverterParameter='新增薪資方案|編輯薪資方案'}"
                                   FontSize="24" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <TextBox md:HintAssist.Hint="薪資名稱 *(?:正職底薪)"
                                 Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,12"/>
                        <TextBox md:HintAssist.Hint="備註(選填)"
                                 Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,12"/>

                        <!-- 薪資類型 -->
                        <TextBlock Text="薪資類型 *"
                                   FontSize="12" FontWeight="Medium" Foreground="{DynamicResource AppSubtleForegroundStrongBrush}"
                                   Margin="0,0,0,4" Opacity="0.7"/>
                        <ComboBox ItemsSource="{Binding SalaryTypes}"
                                  SelectedItem="{Binding EditType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  md:HintAssist.Hint="薪資類型"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource SalaryTypeDisplayConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 時薪組 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Hourly}">
                            <TextBox md:HintAssist.Hint="時薪(元)"
                                     Text="{Binding EditHourlyRate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 月薪組 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Monthly}">
                            <TextBox md:HintAssist.Hint="月薪(元)"
                                     Text="{Binding EditMonthlyBase, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 合約組 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Contract}">
                            <TextBox md:HintAssist.Hint="合約金額(元)"
                                     Text="{Binding EditContractAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,12"/>
                            <TextBox md:HintAssist.Hint="結算週期(?:每月結算一次)"
                                     Text="{Binding EditContractCycle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 加班設定 Expander -->
                        <Expander Header="加班計算設定(不填則依勞基法)"
                                  Style="{StaticResource MaterialDesignExpander}"
                                  Margin="0,8,0,8">
                            <StackPanel Margin="0,12,0,0">
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             md:HintAssist.Hint="加班費倍率1(×)"
                                             Text="{Binding EditOT1Rate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                    <TextBox Grid.Column="1"
                                             md:HintAssist.Hint="加班費倍率2(×)"
                                             Text="{Binding EditOT2Rate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             md:HintAssist.Hint="假日加班倍率(×)"
                                             Text="{Binding EditHolidayRate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             md:HintAssist.Hint="每日最長工時(小時)"
                                             Text="{Binding EditDailyMaxHours, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                    <TextBox Grid.Column="1"
                                             md:HintAssist.Hint="每週最長工時(小時)"
                                             Text="{Binding EditWeeklyMaxHours, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- 加班假日費 -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                   
                                    Margin="0,0,8,0"
                                    Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="儲存" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                   
                                    Content="取消"
                                    Command="{Binding CancelCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- 空白提示 -->
            <Border Grid.Column="1"
                    Visibility="{Binding IsEditing,
                        Converter={StaticResource BoolToVisibilityConverter},
                        ConverterParameter=Inverse}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <md:PackIcon Kind="CurrencyUsd" Width="52" Height="52"
                                 HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="選取左側薪資方案，或建立新方案。"
                               FontSize="14" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                               Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        
        <!-- 右側欄:勞基法設定                        -->
        
        <ScrollViewer Grid.Row="1"
                      Visibility="{Binding ShowLaborLaw,
                          Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                <!-- 提示 InfoBar -->
                <Border Background="{DynamicResource AppInfoBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="InformationOutline" Width="20" Height="20"
                                     Foreground="{DynamicResource AppInfoForegroundBrush}"
                                     VerticalAlignment="Top" Margin="0,2,10,0"/>
                        <TextBlock Text="以下數值僅供參考，實際薪資計算以勞動部公告數值為準。"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppInfoForegroundBrush}"
                                   FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- 月薪組 -->
                <Expander Header="時薪設定" IsExpanded="True"
                          Style="{StaticResource MaterialDesignExpander}"
                          Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="最低時薪(元)"
                                 Text="{Binding LaborLaw.HourlyMinimumWage, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                 md:HintAssist.Hint="每日最長工時(小時)"
                                 Text="{Binding LaborLaw.HourlyDailyMaxHours, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="每週最長工時(小時)"
                                 Text="{Binding LaborLaw.HourlyWeeklyMaxHours, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                 md:HintAssist.Hint="加班費倍率1(第2小時起×)"
                                 Text="{Binding LaborLaw.HourlyOT1Rate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="加班費倍率2(第3小時後×)"
                                 Text="{Binding LaborLaw.HourlyOT2Rate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>
                </Expander>

                <!-- 月薪組 -->
                <Expander Header="月薪設定" IsExpanded="True"
                          Style="{StaticResource MaterialDesignExpander}"
                          Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="最低月薪(元)"
                                 Text="{Binding LaborLaw.MonthlyMinimumWage, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                 md:HintAssist.Hint="每日最長工時(小時)"
                                 Text="{Binding LaborLaw.MonthlyDailyMaxHours, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="每週最長工時(小時)"
                                 Text="{Binding LaborLaw.MonthlyWeeklyMaxHours, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                 md:HintAssist.Hint="加班費倍率1(×)"
                                 Text="{Binding LaborLaw.MonthlyOT1Rate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="加班費倍率2(×)"
                                 Text="{Binding LaborLaw.MonthlyOT2Rate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>
                </Expander>

                <!-- 加班假日費 -->
                <Expander Header="加班費 &amp; 假日費" IsExpanded="True"
                          Style="{StaticResource MaterialDesignExpander}"
                          Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,12,12"
                                 md:HintAssist.Hint="假日加班費率(×)"
                                 Text="{Binding LaborLaw.HolidayOTRate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Grid.Column="1" Margin="0,0,0,12"
                                 md:HintAssist.Hint="每月最長加班(小時)"
                                 Text="{Binding LaborLaw.MaxMonthlyOTHours, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>
                </Expander>

                <!-- 儲存 -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,24">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                           
                            Margin="0,0,8,0"
                            Command="{Binding SaveLaborLawCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="儲存勞基法設定" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                           
                            Content="關閉勞基法設定"
                            Command="{Binding CloseLaborLawCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>






