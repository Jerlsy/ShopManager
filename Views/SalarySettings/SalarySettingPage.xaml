<UserControl x:Class="ShopManager.Views.SalarySettings.SalarySettingPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:models="clr-namespace:ShopManager.Models">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題列 + 子功能按鈕 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock Text="薪資設定" FontTypography="Title" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="出勤法規設定"
                           Icon="{ui:SymbolIcon Symbol=DocumentPerson20}"
                           Command="{Binding OpenLaborLawCommand}"
                           Margin="0,0,8,0"/>
                <ui:Button Content="新增薪資"
                           Icon="{ui:SymbolIcon Symbol=Add24}"
                           Appearance="Primary"
                           Command="{Binding StartNewCommand}"
                           Visibility="{Binding ShowLaborLaw,
                               Converter={StaticResource BoolToVisibilityConverter},
                               ConverterParameter=Inverse}"/>
            </StackPanel>
        </DockPanel>

        <!-- ══════════════════════════════════════════ -->
        <!-- 主視窗：薪資清單 + 右側編輯                   -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              Visibility="{Binding ShowLaborLaw,
                  Converter={StaticResource BoolToVisibilityConverter},
                  ConverterParameter=Inverse}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側清單 -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Salaries}"
                     SelectedItem="{Binding SelectedSalary}"
                     Margin="0,0,16,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Alias}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Type, Converter={StaticResource SalaryTypeDisplayConverter}}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Edit24}" Margin="4,0,0,0"
                                            Command="{Binding DataContext.StartEditCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Delete24}"
                                            Appearance="Danger" Margin="4,0,0,0"
                                            Command="{Binding DataContext.DeleteCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 右側編輯區 -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{Binding IsEditing,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="24">
                    <StackPanel>
                        <ui:TextBlock Text="{Binding SelectedSalary,
                                          Converter={StaticResource NullToStringConverter},
                                          ConverterParameter='新增薪資設定|編輯薪資設定'}"
                                      FontTypography="Subtitle" Margin="0,0,0,16"/>

                        <!-- 別名 -->
                        <ui:TextBlock Text="薪資別名 *" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                        <ui:TextBox PlaceholderText="例：正職時薪、兼職月薪"
                                    Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12"/>

                        <!-- 描述 -->
                        <ui:TextBlock Text="描述" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                        <ui:TextBox PlaceholderText="選填說明"
                                    Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12"/>

                        <!-- 薪資類型 -->
                        <ui:TextBlock Text="薪資類型 *" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SalaryTypes}"
                                  SelectedItem="{Binding EditType}"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource SalaryTypeDisplayConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 時薪制欄位 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Hourly}">
                            <ui:TextBlock Text="時薪（元）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding EditHourlyRate}"
                                          Minimum="0" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 月薪制欄位 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Monthly}">
                            <ui:TextBlock Text="底薪（元）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding EditMonthlyBase}"
                                          Minimum="0" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 合同制欄位 -->
                        <StackPanel Visibility="{Binding EditType,
                                        Converter={StaticResource SalaryTypeVisibilityConverter},
                                        ConverterParameter=Contract}">
                            <ui:TextBlock Text="合同金額（元）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding EditContractAmount}"
                                          Minimum="0" Margin="0,0,0,12"/>
                            <ui:TextBlock Text="計薪週期" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:TextBox PlaceholderText="例：每月、每案件"
                                        Text="{Binding EditContractCycle, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- 加班費率區塊（共用，帶入勞基法預設） -->
                        <Expander Header="加班費率設定（預設帶入勞基法）" Margin="0,8,0,8">
                            <StackPanel Margin="0,12,0,0">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <ui:TextBlock Text="延長工時費率1（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                                        <ui:NumberBox Value="{Binding EditOT1Rate}" Minimum="1" SmallChange="0.01"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ui:TextBlock Text="延長工時費率2（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                                        <ui:NumberBox Value="{Binding EditOT2Rate}" Minimum="1" SmallChange="0.01"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <ui:TextBlock Text="假日加班費率（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                                        <ui:NumberBox Value="{Binding EditHolidayRate}" Minimum="1" SmallChange="0.01"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <ui:TextBlock Text="每日正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                                        <ui:NumberBox Value="{Binding EditDailyMaxHours}" Minimum="1" Maximum="24" SmallChange="0.5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <ui:TextBlock Text="每周正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                                        <ui:NumberBox Value="{Binding EditWeeklyMaxHours}" Minimum="1" Maximum="84" SmallChange="1"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- 操作按鈕 -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <ui:Button Content="儲存" Icon="{ui:SymbolIcon Symbol=Save24}"
                                        Appearance="Primary" Margin="0,0,8,0"
                                        Command="{Binding SaveCommand}"/>
                            <ui:Button Content="取消" Command="{Binding CancelCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- 未選取時的提示 -->
            <Border Grid.Column="1"
                    Visibility="{Binding IsEditing,
                        Converter={StaticResource BoolToVisibilityConverter},
                        ConverterParameter=Inverse}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Money24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <ui:TextBlock Text="請從左側選擇薪資設定，或點選「新增薪資」"
                                  FontTypography="Body"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!-- 子功能頁：出勤法規設定                        -->
        <!-- ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      Visibility="{Binding ShowLaborLaw,
                          Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                <ui:InfoBar Title="此為依台灣勞基法的預設參考值，新增薪資設定時會自動帶入，您可於個別薪資設定中再行調整。"
                             IsOpen="True" Severity="Informational" IsClosable="False"
                             Margin="0,0,0,20"/>

                <!-- 時薪制 -->
                <ui:CardExpander Header="時薪制設定" IsExpanded="True" Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="最低時薪（元）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HourlyMinimumWage}" Minimum="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <ui:TextBlock Text="每日正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HourlyDailyMaxHours}" Minimum="1" Maximum="24"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="每周正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HourlyWeeklyMaxHours}" Minimum="1" Maximum="84"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <ui:TextBlock Text="延長工時費率1（前2小時×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HourlyOT1Rate}" Minimum="1" SmallChange="0.01"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="延長工時費率2（第3小時起×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HourlyOT2Rate}" Minimum="1" SmallChange="0.01"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander>

                <!-- 月薪制 -->
                <ui:CardExpander Header="月薪制設定" IsExpanded="True" Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="最低月薪（元）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MonthlyMinimumWage}" Minimum="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <ui:TextBlock Text="每日正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MonthlyDailyMaxHours}" Minimum="1" Maximum="24"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="每周正常工時上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MonthlyWeeklyMaxHours}" Minimum="1" Maximum="84"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <ui:TextBlock Text="延長工時費率1（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MonthlyOT1Rate}" Minimum="1" SmallChange="0.01"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="延長工時費率2（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MonthlyOT2Rate}" Minimum="1" SmallChange="0.01"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander>

                <!-- 假日 & 加班上限 -->
                <ui:CardExpander Header="假日加班 &amp; 其他規定" IsExpanded="True" Margin="0,0,0,12">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,12">
                            <ui:TextBlock Text="假日出勤費率（×）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.HolidayOTRate}" Minimum="1" SmallChange="0.01"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,0,12">
                            <ui:TextBlock Text="每月加班上限（時）" FontTypography="BodyStrong" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding LaborLaw.MaxMonthlyOTHours}" Minimum="0" Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander>

                <!-- 操作按鈕 -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,24">
                    <ui:Button Content="儲存法規設定" Icon="{ui:SymbolIcon Symbol=Save24}"
                                Appearance="Primary" Margin="0,0,8,0"
                                Command="{Binding SaveLaborLawCommand}"/>
                    <ui:Button Content="返回薪資清單" Command="{Binding CloseLaborLawCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
