<UserControl x:Class="ShopManager.Views.SalarySettings.SalarySettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopManager.Models">

    <Grid Margin="{StaticResource PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="薪資設定" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="設定薪資方案、加班倍率，並管理全店通用的勞基法基礎參數"
                               Style="{StaticResource SubtleTextStyle}" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,12,0"
                            Command="{Binding OpenLaborLawCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileAccount" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="勞基法設定"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding StartNewCommand}"
                            Visibility="{Binding ShowLaborLaw, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="新增薪資方案"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Visibility="{Binding ShowLaborLaw, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 薪資列表 -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="方案清單" Style="{StaticResource SectionTitleStyle}"/>

                    <ListBox ItemsSource="{Binding Salaries}"
                             SelectedItem="{Binding SelectedSalary}"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    CornerRadius="20">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ItemCardStyle}" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Alias}" Style="{StaticResource ItemTitleStyle}"/>
                                            <TextBlock Text="{Binding Type, Converter={StaticResource SalaryTypeDisplayConverter}}"
                                                       Style="{StaticResource FieldLabelStyle}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="34" Height="34"
                                                    Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="34" Height="34"
                                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}">
                                                <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 薪資編輯欄 -->
            <Grid Grid.Column="2">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <md:PackIcon Kind="CurrencyUsd"
                                 Width="80" Height="80"
                                 Opacity="0.12"
                                 HorizontalAlignment="Center"/>
                    <TextBlock Text="請點選左側方案，或點選「新增薪資」開始編輯"
                               Margin="0,20,0,0"
                               Opacity="0.45"
                               Style="{StaticResource ItemTitleStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource EditFormCardStyle}" MaxWidth="680" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedSalary, Converter={StaticResource NullToStringConverter}, ConverterParameter='新增薪資方案|編輯薪資方案'}"
                                       FontSize="{DynamicResource FontSizeListTitle}" FontWeight="SemiBold"
                                       Margin="0,0,0,24"/>

                            <TextBlock Text="薪資方案名稱 *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditAlias, UpdateSourceTrigger=PropertyChanged}"
                                    
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="方案說明 (備註)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                    
                                     Margin="0,0,0,20"
                                     AcceptsReturn="True" MinHeight="60" VerticalContentAlignment="Top"/>

                            <TextBlock Text="薪資類型" Style="{StaticResource FormSectionStyle}"/>
                            <ComboBox ItemsSource="{Binding SalaryTypes}"
                                      SelectedItem="{Binding EditType}"
                                     
                                      md:HintAssist.Hint="選擇類型"
                                      Margin="0,0,0,20">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource SalaryTypeDisplayConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- 動態輸入項 -->
                            <Border Style="{StaticResource ItemCardStyle}" Margin="0,0,0,20" Padding="16,12">
                                <Grid>
                                    <!-- 時薪 -->
                                    <StackPanel Visibility="{Binding EditType, Converter={StaticResource SalaryTypeVisibilityConverter}, ConverterParameter=Hourly}">
                                        <TextBlock Text="基本時薪 (元) *" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Text="{Binding EditHourlyRate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                />
                                    </StackPanel>
                                    <!-- 月薪 -->
                                    <StackPanel Visibility="{Binding EditType, Converter={StaticResource SalaryTypeVisibilityConverter}, ConverterParameter=Monthly}">
                                        <TextBlock Text="月薪底薪 (元) *" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Text="{Binding EditMonthlyBase, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                />
                                    </StackPanel>
                                    <!-- 合約 -->
                                    <Grid Visibility="{Binding EditType, Converter={StaticResource SalaryTypeVisibilityConverter}, ConverterParameter=Contract}">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="合約總額 (元) *" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditContractAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="結算週期" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditContractCycle, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- 加班設定 Expander -->
                            <Expander Header="自訂加班計算設定 (選填，不填則套用勞基法)"
                                      Style="{StaticResource MaterialDesignExpander}"
                                      Margin="0,0,0,24"
                                      Background="{DynamicResource AppPanelBrush}">
                                <StackPanel Margin="16,8,16,8">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="加班費倍率 1 (×)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditOT1Rate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="加班費倍率 2 (×)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditOT2Rate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="假日加班倍率 (×)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditHolidayRate, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="每日最長工時 (小時)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditDailyMaxHours, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="每週最長工時 (小時)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox Text="{Binding EditWeeklyMaxHours, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                        Margin="0,0,12,0"
                                        Command="{Binding SaveCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/>
                                        <TextBlock Text="儲存方案"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="取消"
                                        Width="100"
                                        Command="{Binding CancelCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 勞基法設定區 -->
        <ScrollViewer Grid.Row="1"
                      Visibility="{Binding ShowLaborLaw, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                <Border Style="{StaticResource InfoBoxStyle}" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="InformationOutline" Width="24" Height="24" Foreground="{DynamicResource AppInfoForegroundBrush}" VerticalAlignment="Top" Margin="0,2,14,0"/>
                        <TextBlock Text="以下數值僅供系統自動計算薪資時參考，請定期檢查並確保符合勞動部最新公告。"
                                   TextWrapping="Wrap" Style="{StaticResource PageTitleStyle}" FontSize="{DynamicResource FontSizeBody}" Foreground="{DynamicResource AppInfoForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Expander Header="時薪人員標準" IsExpanded="True" Style="{StaticResource MaterialDesignExpander}" Margin="0,0,0,16">
                            <StackPanel Margin="16,8,16,8">
                                <TextBlock Text="法定最低時薪 (元)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.HourlyMinimumWage}" Margin="0,0,0,16"/>
                                <TextBlock Text="每日工時上限 (小時)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.HourlyDailyMaxHours}" Margin="0,0,0,16"/>
                                <TextBlock Text="加班倍率 1（第 2 小時起）" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.HourlyOT1Rate}" Margin="0,0,0,16"/>
                                <TextBlock Text="加班倍率 2（第 3 小時起）" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.HourlyOT2Rate}" Margin="0,0,0,8"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Expander Header="月薪人員標準" IsExpanded="True" Style="{StaticResource MaterialDesignExpander}" Margin="0,0,0,16">
                            <StackPanel Margin="16,8,16,8">
                                <TextBlock Text="法定最低月薪 (元)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.MonthlyMinimumWage}" Margin="0,0,0,16"/>
                                <TextBlock Text="每日工時上限 (小時)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.MonthlyDailyMaxHours}" Margin="0,0,0,16"/>
                                <TextBlock Text="加班倍率 1（第 2 小時起）" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.MonthlyOT1Rate}" Margin="0,0,0,16"/>
                                <TextBlock Text="加班倍率 2（第 3 小時起）" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LaborLaw.MonthlyOT2Rate}" Margin="0,0,0,8"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Grid>

                <Expander Header="通用限制設定" IsExpanded="True" Style="{StaticResource MaterialDesignExpander}" Margin="0,0,0,24">
                    <Grid Margin="16,8,16,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="假日加班費率 (×)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding LaborLaw.HolidayOTRate}" Margin="0,0,0,8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="每月加班時數上限 (小時)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding LaborLaw.MaxMonthlyOTHours}" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,12,0" Command="{Binding SaveLaborLawCommand}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0"/><TextBlock Text="儲存勞基法設定"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="返回薪資列表" Width="140" Command="{Binding CloseLaborLawCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>